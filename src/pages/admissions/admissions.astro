<style>
    /* Admissions hero: fluid type + zoom-friendly layout */
    .admissions-hero-lede {
        font-size: clamp(0.9375rem, 0.82rem + 0.65vw, 1.4375rem);
        line-height: 1.55;
    }
    /* Slightly stronger cover on narrow / tall-zoom viewports */
    @media (max-width: 520px) {
        .admissions-hero .video-pan {
            width: 140vw;
            height: 140vh;
            min-width: 140%;
            min-height: 140%;
        }
    }
    @media (prefers-reduced-motion: reduce) {
        .admissions-hero .video-pan {
            animation: none;
            transform: translate(-50%, -50%) scale(1.28);
        }
    }

    /* Video panning animation - smooth movement for 1920x1080 video */
    @keyframes videoPan {
        0% {
            transform: translate(-50%, -50%) scale(1.5) translate(0%, 0%);
        }
        25% {
            transform: translate(-50%, -50%) scale(1.5) translate(-5%, -3%);
        }
        50% {
            transform: translate(-50%, -50%) scale(1.5) translate(-8%, -5%);
        }
        75% {
            transform: translate(-50%, -50%) scale(1.5) translate(-5%, -3%);
        }
        100% {
            transform: translate(-50%, -50%) scale(1.5) translate(0%, 0%);
        }
    }
    
    .video-pan {
        position: absolute;
        top: 50%;
        left: 50%;
        width: 120vw;
        height: 120vh;
        min-width: 120%;
        min-height: 120%;
        object-fit: cover;
        transform-origin: center center;
        animation: videoPan 20s ease-in-out infinite;
        will-change: transform;
    }
    
    /* Ensure video container covers full viewport */
    section.relative.bg-msu-main-color {
        overflow: hidden;
    }
    
    .absolute.inset-0.z-0 {
        overflow: hidden;
    }
</style>

        <script src="../../js/animate.js" ></script>
