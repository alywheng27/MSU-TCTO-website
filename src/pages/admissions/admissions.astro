<script>
// Video starts at 0:00:00 and loops at 0:01:14 (74 seconds)
document.addEventListener('DOMContentLoaded', function() {
  const el = document.getElementById('hero-video');
  const video = el instanceof HTMLVideoElement ? el : null;
  if (!video) return;
  video.currentTime = 0;
  video.addEventListener('timeupdate', function() {
    if (video.currentTime >= 74) {
      video.currentTime = 0;
    }
  });
  video.addEventListener('ended', function() {
    video.currentTime = 0;
    video.play();
  });
});
</script>