  >
    window.__ICTO_GOOGLE_FORM_ACTION = ictoGoogleFormAction;
    window.__ICTO_GOOGLE_FORM_ENTRIES = ictoGoogleFormEntries;
    window.__ICTO_GOOGLE_FORM_PAGE_HISTORY = ictoGoogleFormPageHistory;
    window.__ICTO_GOOGLE_FORM_FBZX = ictoGoogleFormFbzx;
    window.__ICTO_SHEET_INGEST_ENABLED = ictoSheetIngestEnabled;
    window.__ICTO_RECAPTCHA_SITE_KEY = ictoRecaptchaSiteKey;
    window.__ICTO_CAPTCHA_TTL_SECONDS = ictoCaptchaTtlSeconds;
