        ictRc.addEventListener('click', function () {
          var refEl = document.getElementById('icto-receipt-ref');
          var t = refEl ? refEl.textContent.trim() : '';
          if (!t || t === '\u2014') return;
          function showCopiedToast() {
            var toast = document.getElementById('icto-receipt-copy-toast');
            if (!toast) return;
            if (toast._ictoToastTimer) {
              clearTimeout(toast._ictoToastTimer);
              toast._ictoToastTimer = null;
            }
            toast.classList.remove('hidden');
            toast._ictoToastTimer = setTimeout(function () {
              toast.classList.add('hidden');
            }, 2200);
          }
          function fallbackCopy() {
            var ta = document.createElement('textarea');
            ta.value = t;
            ta.setAttribute('readonly', '');
            ta.style.position = 'fixed';
            ta.style.opacity = '0';
            document.body.appendChild(ta);
            ta.select();
            try {
              document.execCommand('copy');
            } catch (e) {
              /* ignore */
            }
            document.body.removeChild(ta);
            showCopiedToast();
          }
          if (navigator.clipboard && navigator.clipboard.writeText) {
            navigator.clipboard
              .writeText(t)
              .then(showCopiedToast)
              .catch(fallbackCopy);
          } else {
            fallbackCopy();
          }
        });
      }
      var ictRd = document.getElementById('icto-receipt-download');
      if (ictRd) {
        ictRd.addEventListener('click', function () {
          var refEl = document.getElementById('icto-receipt-ref');
          var refT = refEl && refEl.textContent ? refEl.textContent.trim() : '';
          if (!refT || refT === '\u2014') return;
          ictRd.setAttribute('disabled', 'disabled');
          ictoBuildReceiptJpegBlob(function (blob) {
            ictRd.removeAttribute('disabled');
            if (!blob) {
              window.alert('Could not generate the receipt image. Try print or copy the reference instead.');
              return;
            }
            var url = URL.createObjectURL(blob);
            var a = document.createElement('a');
            a.href = url;
            a.download = 'ICTO-receipt-' + safeIctoReceiptDownloadBasename(refT) + '.jpg';
            a.rel = 'noopener';
            document.body.appendChild(a);
            a.click();
            document.body.removeChild(a);
            setTimeout(function () {
              URL.revokeObjectURL(url);
            }, 2500);
          });
        });
      }

      var ictRp = document.getElementById('icto-receipt-print');
      if (ictRp) {
        ictRp.addEventListener('click', function () {
          var rm = document.getElementById('icto-receipt-modal');
          if (rm && rm.classList.contains('is-open')) setIctoReceiptPrintMode(true);
          window.print();
        });
      }

      /** Inlined from frontmatter (`window.__ICTO_GOOGLE_FORM_ACTION`); never duplicate `/formResponse` strings here. */
      var ICTO_GOOGLE_FORM_RESPONSE =
        typeof window !== 'undefined' && window.__ICTO_GOOGLE_FORM_ACTION
          ? String(window.__ICTO_GOOGLE_FORM_ACTION).trim()
          : '';

      function setGF(logicalKey, value) {
        if (!ICTO_GFORM || !ICTO_GFORM[logicalKey]) return;
        var nm = ICTO_GFORM[logicalKey];
        var v = value == null ? '' : String(value);
        /* `elements.namedItem` can return a RadioNodeList or omit edge cases — mirror robust updates for every matching control */
        try {
          /* `entry.*` IDs are safe ASCII (digits/dots); same pattern as officefeedback literal names */
          var list = form.querySelectorAll(
            'input[name="' + nm + '"], textarea[name="' + nm + '"], select[name="' + nm + '"]'
          );
          if (list && list.length) {
            list.forEach(function (el) {
              if (el && 'value' in el && el.type !== 'file' && el.type !== 'button') el.value = v;
            });
            return;
          }
        } catch (eQk) {}
        var el = form.elements.namedItem(nm);
        if (el && el.length && typeof el.item === 'function') {
          for (var qi = 0; qi < el.length; qi++) {
            var one = el.item(qi);
            if (one && 'value' in one && one.type !== 'file' && one.type !== 'button') one.value = v;
          }
          return;
        }
        if (el && 'value' in el) el.value = v;
      }

      /**
       * Fill computed/hidden Google fields before POST (portal labels + aggregates). Visible `entry.*` inputs keep user edits.
       * @param {object} opts Optional: skipDocEntryNames — Set of `entry.*` ids that will be sent as multipart files instead of text.
       */
      function syncIctoGoogleEntryComputedFields(p, apptRefForGoogle, opts) {
        if (!p || !ICTO_GFORM.serviceType) return;
        opts = opts || {};
        var skipDoc = opts.skipDocEntryNames || null;
        var roleRaw = valRole();
        var idFrontNm =
          roleRaw === 'student' ? uploadedFileName('student_id_front') : uploadedFileName('staff_faculty_id_front');
        var idBackNm =
          roleRaw === 'student' ? uploadedFileName('student_id_back') : uploadedFileName('staff_faculty_id_back');
        var corNmGF = uploadedFileName('student_cor_file');
        var idFrontTxt = idFrontNm
          ? 'File: ' + idFrontNm + ' (uploaded via MSU-TCTO portal)'
          : 'Uploaded via MSU-TCTO web form (see Google Form response).';
        var idBackTxt = idBackNm
          ? 'File: ' + idBackNm + ' (uploaded via MSU-TCTO portal)'
          : 'Uploaded via MSU-TCTO web form (see Google Form response).';
        var corTxt =
          roleRaw === 'student'
            ? corNmGF
              ? 'File: ' + corNmGF + ' (portal)'
              : 'Uploaded via portal'
            : 'Not applicable (faculty/staff requester)';
        var capEl = document.getElementById('ict-sig-timestamp');
        var captureAt =
          capEl && capEl.textContent && capEl.textContent.trim() !== '\u2014'
            ? capEl.textContent.trim()
            : p.SignatureRecordedAt || p.submittedAt || '';
        setGF('serviceType', String(p.ServiceType || ''));
        setGF(
          'localRecordId',
          String(p.SubmissionId || p.submissionId || '')
        );
        setGF('appointmentReference', String(apptRefForGoogle || ''));
        /* Checkbox question: values must match Google options exactly (Student / Faculty / Staff). */
        setGF('requesterInformation', String(p.RequesterType || '').trim());
        if (!skipDoc || !skipDoc.has(ICTO_GFORM.validIdFront)) setGF('validIdFront', idFrontTxt);
        if (!skipDoc || !skipDoc.has(ICTO_GFORM.validIdBack)) setGF('validIdBack', idBackTxt);
        if (!skipDoc || !skipDoc.has(ICTO_GFORM.certificateOfRegistrationCor))
          setGF('certificateOfRegistrationCor', corTxt);
        /* Real POST uses duplicate `entry.*` keys (see buildIctoGoogleFormDataFromDom); keep DOM fields empty. */
        setGF('hardwareAndTechnicalAssistance', '');
        setGF('softwareInstallation', '');
        setGF(
          'liabilityDisclaimer',
          p.liabilityAccepted || p.LiabilityAccepted ? 'Yes' : ''
        );
        /* Google Form “ApproveHandwritten” — must match the published option string (e.g. YES). */
        setGF(
          'approveHandwritten',
          p.ElectronicSignatureAcknowledged || p.electronicSignatureAcknowledged ? 'YES' : ''
        );
        if (!skipDoc || !ICTO_GFORM.eSignature || !skipDoc.has(ICTO_GFORM.eSignature)) {
          setGF('eSignature', 'Electronic signature captured on MSU-TCTO ICTO web portal');
        }
        setGF('captureAt', captureAt);
      }

      /**
       * Like officefeedback: `new FormData(form)` only includes Google `entry.*` fields once portal-only controls are disabled (hw_*, liability_ack, etc.).
       * Files use wrong `name=` on DOM inputs — excluded here and appended separately with correct `entry.*`.
       *
       * @param {Set<string>|null} skipEntryNames Omit these `entry.*` keys (multipart file slots).
       */
      function buildIctoGoogleFormDataFromDom(pPayload, skipEntryNames) {
        var remarkEntry = ICTO_GFORM.remarksAdditionalDetailsOptional;
        var hwEntry = ICTO_GFORM.hardwareAndTechnicalAssistance;
        var swEntry = ICTO_GFORM.softwareInstallation;
        /** @type {{ el: HTMLInputElement | HTMLTextAreaElement | HTMLSelectElement | HTMLButtonElement, d: boolean }[]} */
        var restore = [];

        try {
          var allNamed = form.querySelectorAll('input[name], textarea[name], select[name], button[name]');
          for (var xi = 0; xi < allNamed.length; xi++) {
            var node = /** @type {HTMLInputElement & { name?: string }} */ (allNamed[xi]);
            var rn = node.name;
            if (!rn || rn.indexOf('entry.') === 0) continue;
            restore.push({ el: node, d: !!node.disabled });
            node.disabled = true;
          }

          var fd = new FormData(form);

          for (var ri = 0; ri < restore.length; ri++) {
            restore[ri].el.disabled = restore[ri].d;
          }

          if (skipEntryNames && skipEntryNames.size) {
            skipEntryNames.forEach(function (sk) {
              fd.delete(sk);
            });
          }

          if (remarkEntry) {
            fd.delete(remarkEntry);
            /* Sheet / Google Form: only user-typed remarks. RequesterRemarks adds portal meta for internal payloads — do not paste that into Remarks / Additional Details (Optional). */
            fd.append(remarkEntry, gField('remarksAdditionalDetailsOptional'));
          }

          if (hwEntry) {
            fd.delete(hwEntry);
            Object.keys(ICTO_HW_LABELS).forEach(function (hn) {
              var hcb = form.elements.namedItem(hn);
              if (hcb && /** @type {HTMLInputElement} */ (hcb).type === 'checkbox' && hcb.checked)
                fd.append(hwEntry, ICTO_HW_LABELS[hn]);
            });
          }

          if (swEntry) {
            fd.delete(swEntry);
            Object.keys(ICTO_SW_LABELS).forEach(function (sn) {
              var scb = form.elements.namedItem(sn);
              if (scb && /** @type {HTMLInputElement} */ (scb).type === 'checkbox' && scb.checked)
                fd.append(swEntry, ICTO_SW_LABELS[sn]);
            });
          }

          /* Native Google Forms often POST these alongside `entry.*`; keep parity with Inspect → Network without requiring `officefeedback`'s sparse body */
          var pgHist =
            typeof window !== 'undefined' && typeof window.__ICTO_GOOGLE_FORM_PAGE_HISTORY === 'string'
              ? window.__ICTO_GOOGLE_FORM_PAGE_HISTORY.trim()
              : '';
          if (pgHist) fd.append('pageHistory', pgHist);

          fd.append('fvv', '1');
          fd.append('submit', 'Submit');

          var fuIds = [];
          if (ICTO_GFORM) {
            ['validIdFront', 'validIdBack', 'certificateOfRegistrationCor', 'eSignature'].forEach(function (fk) {
              var ent = ICTO_GFORM[fk];
              if (ent && typeof ent === 'string' && ent.indexOf('entry.') === 0) fuIds.push(ent.slice(6));
            });
          }
          if (fuIds.length) fd.append('fuIds', fuIds.join(','));

          var fbzxW =
            typeof window !== 'undefined' && typeof window.__ICTO_GOOGLE_FORM_FBZX === 'string'
              ? window.__ICTO_GOOGLE_FORM_FBZX.trim()
              : '';
          if (fbzxW) fd.append('fbzx', fbzxW);
          fd.append('submissionTimestamp', '-1');

          return fd;
        } catch (eFd) {
          for (var rj = 0; rj < restore.length; rj++) {
            restore[rj].el.disabled = restore[rj].d;
          }
          throw eFd;
        }
      }

      /** Turn `canvas.toDataURL('image/jpeg', …)` output into a `File` for Google multipart upload (`entry.*` file question). */
      function ictoDataUrlToSignatureFile(dataUrl, filename) {
        if (!dataUrl || typeof dataUrl !== 'string' || dataUrl.indexOf('data:image') !== 0) return null;
        try {
          var comma = dataUrl.indexOf(',');
          if (comma < 0) return null;
          var meta = dataUrl.slice(0, comma);
          var payload = dataUrl.slice(comma + 1);
          var mime = 'image/jpeg';
          var mh = /^data:([^;,]+)/.exec(meta);
          if (mh && mh[1]) mime = mh[1];
          if (!/;base64/i.test(meta)) return null;
          var bin = window.atob(payload);
          var bytes = new Uint8Array(bin.length);
          for (var bi = 0; bi < bin.length; bi++) bytes[bi] = bin.charCodeAt(bi);
          var fn =
            typeof filename === 'string' && filename.trim()
              ? filename.trim()
              : 'ICTO-electronic-signature.jpg';
          if (typeof File !== 'undefined') {
            return new File([bytes], fn, { type: mime || 'image/jpeg' });
          }
          return null;
        } catch (eConv) {
          return null;
        }
      }

      /** Map portal file inputs → Google file-upload `entry.*` ids; faculty/staff get a placeholder COR text file so required COR accepts a file part. */
      function buildIctoGoogleFileSlotMoves(roleRaw) {
        var moves = [];
        var ef = ICTO_GFORM.validIdFront;
        var eb = ICTO_GFORM.validIdBack;
        var ec = ICTO_GFORM.certificateOfRegistrationCor;
        if (!ef || !eb || !ec) return moves;

        if (roleRaw === 'student') {
          var sf = document.getElementById('student-id-front');
          var sb = document.getElementById('student-id-back');
          var sc = document.getElementById('student-cor-file');
          if (sf && sf.files && sf.files.length) moves.push({ input: sf, entryName: ef });
          if (sb && sb.files && sb.files.length) moves.push({ input: sb, entryName: eb });
          if (sc && sc.files && sc.files.length) moves.push({ input: sc, entryName: ec });
        } else if (roleRaw === 'faculty' || roleRaw === 'staff') {
          var ff = document.getElementById('staff-faculty-id-front');
          var fb = document.getElementById('staff-faculty-id-back');
          if (ff && ff.files && ff.files.length) moves.push({ input: ff, entryName: ef });
          if (fb && fb.files && fb.files.length) moves.push({ input: fb, entryName: eb });
          if (typeof File !== 'undefined') {
            var note =
              'Not applicable — faculty/staff request (no student Certificate of Registration).\nUse Valid ID uploads and other answers in this response.';
            var blob = new Blob([note], { type: 'text/plain;charset=utf-8' });
            var placeholder = new File([blob], 'COR-not-applicable-faculty-staff.txt', {
              type: 'text/plain;charset=utf-8',
            });
            moves.push({ synthetic: true, entryName: ec, file: placeholder });
          }
        }
        return moves;
      }

      /** Attach real / synthetic uploads to `FormData` (`entry.*` file questions). */
      function ictoAppendGoogleFileSlots(fd, fileMoves) {
        if (!fd || !fileMoves || !fileMoves.length) return fd;
        fileMoves.forEach(function (m) {
          if (m.synthetic && m.file) {
            fd.append(m.entryName, m.file, m.file.name || 'upload');
          } else if (m.input && m.input.type === 'file' && m.input.files && m.input.files.length) {
            var uf = m.input.files[0];
            fd.append(m.entryName, uf, uf.name || 'upload');
          }
        });
        return fd;
      }

      /**
       * Iframe navigational POST fallback (multipart moves real file inputs; synthetic files via DataTransfer).
       */
      function ictoGoogleFormSubmitIframeFallback(fd, actionUrl, fileMoves) {
        var hiddenForm = document.createElement('form');
        hiddenForm.style.display = 'none';
        hiddenForm.method = 'POST';
        hiddenForm.action = actionUrl;
        hiddenForm.target = 'icto_hidden_gform_submit';
        hiddenForm.acceptCharset = 'UTF-8';
        var multipart = !!(fileMoves && fileMoves.length);
        hiddenForm.enctype = multipart ? 'multipart/form-data' : 'application/x-www-form-urlencoded';
        hiddenForm.setAttribute('novalidate', '');
        fd.forEach(function (value, key) {
          if (typeof Blob !== 'undefined' && value instanceof Blob) return;
          var input = document.createElement('input');
          input.type = 'hidden';
          input.name = key;
          input.value = value == null ? '' : String(value);
          hiddenForm.appendChild(input);
        });

        var moved = [];
        var synthetics = [];
        if (multipart) {
          fileMoves.forEach(function (m) {
            if (m.synthetic && m.file && typeof DataTransfer !== 'undefined') {
              var sin = document.createElement('input');
              sin.type = 'file';
              sin.name = m.entryName;
              sin.style.display = 'none';
              sin.setAttribute('tabindex', '-1');
              sin.setAttribute('aria-hidden', 'true');
              try {
                var dt = new DataTransfer();
                dt.items.add(m.file);
                sin.files = dt.files;
                hiddenForm.appendChild(sin);
                synthetics.push(sin);
              } catch (eSyn) {
                /* ignore synthetic file attachment */
              }
              return;
            }
            var inp = m.input;
            if (!inp || inp.type !== 'file' || !inp.files || !inp.files.length) return;
            var prevName = inp.name;
            var prevParent = inp.parentNode;
            inp.name = m.entryName;
            hiddenForm.appendChild(inp);
            moved.push({ el: inp, prevName: prevName, prevParent: prevParent });
          });
        }

        document.body.appendChild(hiddenForm);
        hiddenForm.submit();

        var restoreDelay = multipart ? 2500 : 10000;
        setTimeout(function () {
          moved.forEach(function (m) {
            m.el.name = m.prevName;
            if (m.prevParent) m.prevParent.appendChild(m.el);
          });
          synthetics.forEach(function (s) {
            if (s.parentNode) s.parentNode.removeChild(s);
          });
          if (hiddenForm.parentNode) hiddenForm.parentNode.removeChild(hiddenForm);
        }, restoreDelay);
      }

      /**
       * Primary: fetch + FormData body (officefeedback-style) + no-cors. Files appended to the same payload.
       * Fallback: hidden iframe POST.
       */
      function ictoGoogleFormSubmitNavigate(fd, actionUrl, fileMoves) {
        function runFallback(reason) {
          if (reason && typeof console !== 'undefined' && console.warn) {
            console.warn('ICTO Google Form: submitting via iframe fallback.', reason);
          }
          ictoGoogleFormSubmitIframeFallback(fd, actionUrl, fileMoves);
        }

        try {
          ictoAppendGoogleFileSlots(fd, fileMoves);
        } catch (eA) {
          runFallback(eA);
          return;
        }

        if (typeof fetch !== 'function') {
          runFallback('fetch unavailable');
          return;
        }

        fetch(actionUrl, {
          method: 'POST',
          mode: 'no-cors',
          credentials: 'omit',
          body: fd,
        }).catch(function (eFu) {
          runFallback(eFu);
        });
      }

      function resolveAppointmentReferenceForGoogle(p, appointmentReferenceOverride) {
        if (!p) return '';
        if (appointmentReferenceOverride != null && String(appointmentReferenceOverride).trim() !== '') {
          return String(appointmentReferenceOverride).trim();
        }
        if (p.appointmentReference != null && String(p.appointmentReference).trim() !== '')
          return String(p.appointmentReference).trim();
        if (p.AppointmentReference != null && String(p.AppointmentReference).trim() !== '')
          return String(p.AppointmentReference).trim();
        if (p.Fields && p.Fields.AppointmentReference != null)
          return String(p.Fields.AppointmentReference).trim();
        if (p.fields && p.fields.AppointmentReference != null)
          return String(p.fields.AppointmentReference).trim();
        if (p.Item && p.Item.AppointmentReference != null)
          return String(p.Item.AppointmentReference).trim();
        if (p.item && p.item.AppointmentReference != null)
          return String(p.item.AppointmentReference).trim();
        return '';
      }

      function formDataToEntriesMap(fd) {
        /** @type {Record<string, string | string[]>} */
        var entries = {};
        if (!fd || typeof fd.forEach !== 'function') return entries;
        fd.forEach(function (v, k) {
          if (typeof Blob !== 'undefined' && v instanceof Blob) return;
          var s = v == null ? '' : String(v);
          if (Object.prototype.hasOwnProperty.call(entries, k)) {
            var cur = entries[k];
            if (Array.isArray(cur)) cur.push(s);
            else entries[k] = [cur, s];
          } else {
            entries[k] = s;
          }
        });
        return entries;
      }

      /** Strip `pageHistory`, `fbzx`, etc. — only Send `entry.*` to ingest (legacy fallback would dump one blob cell otherwise). */
      function pickGoogleEntryKeysOnly(entries) {
        /** @type {Record<string, string | string[]>} */
        var out = {};
        if (!entries || typeof entries !== 'object') return out;
        Object.keys(entries).forEach(function (k) {
          if (/^entry\.\d+$/.test(k)) out[k] = /** @type {string | string[]} */ (entries[k]);
        });
        return out;
      }

      function fileToBase64(blob) {
        return new Promise(function (resolve, reject) {
          if (!blob) {
            resolve('');
            return;
          }
          try {
            var fr = new FileReader();
            fr.onload = function () {
              var r = /** @type {string} */ (fr.result || '');
              var comma = r.indexOf(',');
              resolve(comma >= 0 ? r.slice(comma + 1) : r);
            };
            fr.onerror = function () {
              reject(new Error('Cannot read attachment'));
            };
            fr.readAsDataURL(blob instanceof Blob ? blob : new Blob());
          } catch (eR) {
            reject(eR);
          }
        });
      }

      function buildSheetIngestFilesPayload(fileMoves) {
        /** @typedef {{ entry: string, filename: string, mimeType: string, dataBase64: string }} FilePart */
        /** @type {Promise<FilePart[]>} */
        var list = [];
        fileMoves.forEach(function (m) {
          /** @type {Blob | File | null} */
          var f = null;
          if (m.synthetic && m.file) f = m.file;
          else if (m.input && m.input.files && m.input.files.length) f = m.input.files[0];
          if (!f) return;
          list.push(
            fileToBase64(f).then(function (b64) {
              /** @type {FilePart} */
              var part = {
                entry: m.entryName,
                filename: ('name' in f && f.name) || 'upload.bin',
                mimeType: ('type' in f && f.type) ? f.type : 'application/octet-stream',
                dataBase64: b64,
              };
              return part;
            })
          );
        });
        return Promise.all(list);
      }

      function loadIctoRecaptchaScript(siteKey) {
        return new Promise(function (resolve, reject) {
          if (typeof window === 'undefined') return reject(new Error('Browser context unavailable.'));
          if (window.grecaptcha && typeof window.grecaptcha.execute === 'function') return resolve();
          var existing = document.querySelector('script[data-icto-recaptcha="1"]');
          if (existing) {
            existing.addEventListener('load', function () {
              resolve();
            });
            existing.addEventListener('error', function () {
              reject(new Error('reCAPTCHA script failed to load.'));
            });
            return;
          }
          var script = document.createElement('script');
          script.src = 'https://www.google.com/recaptcha/api.js?render=' + encodeURIComponent(siteKey);
          script.async = true;
          script.defer = true;
          script.setAttribute('data-icto-recaptcha', '1');
          script.onload = function () {
            resolve();
          };
          script.onerror = function () {
            reject(new Error('reCAPTCHA script failed to load.'));
          };
          document.head.appendChild(script);
        });
      }

      function getIctoRecaptchaToken(actionName) {
        if (typeof window === 'undefined') return Promise.resolve('');
        var siteKey =
          typeof window.__ICTO_RECAPTCHA_SITE_KEY === 'string'
            ? window.__ICTO_RECAPTCHA_SITE_KEY.trim()
            : '';
        if (!siteKey) return Promise.resolve('');
        return loadIctoRecaptchaScript(siteKey).then(function () {
          if (!window.grecaptcha || typeof window.grecaptcha.ready !== 'function') {
            throw new Error('reCAPTCHA library unavailable.');
          }
          return new Promise(function (resolve, reject) {
            window.grecaptcha.ready(function () {
              try {
                var p = window.grecaptcha.execute(siteKey, {
                  action: actionName || 'icto_service_submit',
                });
                Promise.resolve(p)
                  .then(function (token) {
                    resolve(typeof token === 'string' ? token : '');
                  })
                  .catch(function () {
                    reject(new Error('Could not generate reCAPTCHA token.'));
                  });
              } catch (eExec) {
                reject(new Error('Could not generate reCAPTCHA token.'));
              }
            });
          });
        });
      }

      /**
       * Google Sheet + Apps Script ingest (server-side relay). Bypasses docs.google.com 401 when Form auth blocks bare POST.
       * @returns {Promise<void>}
       */
      function mirrorSubmissionToSheetIngest(p, appointmentReferenceOverride, recaptchaToken) {
        if (!p) return Promise.resolve();
        var apptRefForGoogle = resolveAppointmentReferenceForGoogle(p, appointmentReferenceOverride);
        if (!ICTO_GFORM || !ICTO_GFORM.serviceType) {
          return Promise.reject(new Error('Form configuration missing'));
        }

        var roleRaw = valRole();
        var fileMoves = buildIctoGoogleFileSlotMoves(roleRaw);

        var esEntry = ICTO_GFORM.eSignature;
        var sigDataUrl =
          typeof p.ElectronicSignatureImage === 'string'
            ? p.ElectronicSignatureImage.trim()
            : typeof p.electronicSignatureImage === 'string'
              ? p.electronicSignatureImage.trim()
              : '';
        if (esEntry && sigDataUrl && typeof File !== 'undefined') {
          var sigFi = ictoDataUrlToSignatureFile(sigDataUrl, 'ICTO-electronic-signature.jpg');
          if (sigFi) fileMoves.push({ synthetic: true, entryName: esEntry, file: sigFi });
        }

        var skipDoc = new Set();
        for (var ix = 0; ix < fileMoves.length; ix++) skipDoc.add(fileMoves[ix].entryName);

        syncIctoGoogleEntryComputedFields(p, apptRefForGoogle, { skipDocEntryNames: skipDoc });

        var fd = buildIctoGoogleFormDataFromDom(p, skipDoc.size ? skipDoc : null);
        var entries = pickGoogleEntryKeysOnly(formDataToEntriesMap(fd));

        return buildSheetIngestFilesPayload(fileMoves).then(function (files) {
          /** @type {Record<string,string>} */
          var entryIdByCol =
            typeof window !== 'undefined' &&
            window.__ICTO_ENTRY_ID_BY_FORM_HEADER &&
            typeof window.__ICTO_ENTRY_ID_BY_FORM_HEADER === 'object'
              ? window.__ICTO_ENTRY_ID_BY_FORM_HEADER
              : {};
          return fetch('/api/icto-service-sheet-ingest', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json;charset=utf-8' },
            body: JSON.stringify({
              hp_company_url: val('hp_company_url'),
              recaptchaToken: typeof recaptchaToken === 'string' ? recaptchaToken : '',
              recaptchaAction: 'icto_service_submit',
              submissionId: p.SubmissionId || '',
              appointmentReference: apptRefForGoogle,
              submittedAt:
                typeof p.SubmittedAt === 'string'
                  ? p.SubmittedAt
                  : typeof p.submittedAt === 'string'
                    ? p.submittedAt
                    : new Date().toISOString(),
              entries: entries,
              files: files,
              entryIdByColumnHeader: entryIdByCol,
            }),
          }).then(function (res) {
            return res.json().then(function (j) {
              if (!res.ok || !j || j.success !== true) {
                var msg =
                  j && typeof j.error === 'string'
                    ? j.error
                    : 'Server returned ' + (res.status || '') + '';
                throw new Error(msg);
              }
            });
          });
        });
      }

      /** POST via fetch(no-cors) + FormData (primary); iframe POST on failure — matches officefeedback. */
      function mirrorSubmissionToGoogleForm(p, appointmentReferenceOverride) {
        if (!p) return;
        var url = ICTO_GOOGLE_FORM_RESPONSE;
        if (!url) {
          if (typeof console !== 'undefined' && console.warn)
            console.warn('ICTO: Missing Google Form action URL (__ICTO_GOOGLE_FORM_ACTION).');
          return;
        }
        try {
          var roleRaw = valRole();
          var fileMoves = buildIctoGoogleFileSlotMoves(roleRaw);

          var esEntry = ICTO_GFORM.eSignature;
          var sigDataUrl =
            p && typeof p.ElectronicSignatureImage === 'string'
              ? p.ElectronicSignatureImage.trim()
              : p && typeof p.electronicSignatureImage === 'string'
                ? p.electronicSignatureImage.trim()
                : '';
          if (esEntry && sigDataUrl && typeof File !== 'undefined') {
            var sigFi2 = ictoDataUrlToSignatureFile(sigDataUrl, 'ICTO-electronic-signature.jpg');
            if (sigFi2) fileMoves.push({ synthetic: true, entryName: esEntry, file: sigFi2 });
          }

          var apptRefForGoogle = resolveAppointmentReferenceForGoogle(p, appointmentReferenceOverride);
          var skipDoc = new Set();
          for (var ix = 0; ix < fileMoves.length; ix++) skipDoc.add(fileMoves[ix].entryName);
          syncIctoGoogleEntryComputedFields(p, apptRefForGoogle, { skipDocEntryNames: skipDoc });
          var fd2 = buildIctoGoogleFormDataFromDom(p, skipDoc.size ? skipDoc : null);
          ictoGoogleFormSubmitNavigate(fd2, url, fileMoves.length ? fileMoves : null);
        } catch (e) {
          if (typeof console !== 'undefined' && console.error) console.error('ICTO Google Form mirror failed:', e);
        }
      }

      function populateIctoReceipt(p) {
