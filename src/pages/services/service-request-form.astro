      /**
       * Builds the submission snapshot used for the Google Form POST and on-screen receipt.
       */
      function collectRequestPayload(appointmentRefOpt) {
        var appointmentReference =
          typeof appointmentRefOpt === 'string' ? appointmentRefOpt.trim() : '';
        const checkedServices = [];
        form.querySelectorAll('input[type="checkbox"]').forEach(function (cb) {
          if (
            cb.checked &&
            cb.name &&
            cb.name !== 'liability_ack' &&
