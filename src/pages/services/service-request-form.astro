        <div
          id="icto-form-modal-panel"
          class="icto-modal-panel pointer-events-auto w-full sm:max-w-4xl max-h-[100svh] sm:max-h-[90vh] flex flex-col rounded-t-2xl sm:rounded-2xl border border-slate-200/80 dark:border-slate-600 bg-white dark:bg-slate-900 shadow-2xl"
        >
          <div class="bg-[#61063B] text-white px-5 sm:px-8 py-4 flex items-start justify-between gap-4 shrink-0 rounded-t-2xl sm:rounded-t-2xl">
            <div class="min-w-0">
              <p class="text-xs font-semibold uppercase tracking-widest text-white/70">ICTO — Service request</p>
              <h2 id="icto-modal-title" class="text-lg sm:text-xl font-bold font-serif mt-1">Service request</h2>
              <p id="icto-modal-subtitle" class="text-sm text-white/85 mt-1">Information and Communications Technology Office</p>
            </div>
            <button
              type="button"
              class="shrink-0 rounded-lg p-2 text-white/90 hover:bg-white/10 transition-colors focus:outline-none focus-visible:ring-2 focus-visible:ring-white"
              data-close-icto-modal
              id="icto-modal-close"
              aria-label="Close form"
            >
              <svg class="h-6 w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
            </button>
          </div>

          <div id="icto-form-modal-scroll" class="overflow-y-auto flex-1 min-h-0">
        <form
          id="icto-maintenance-form"
          class="text-slate-800 dark:text-slate-200"
          novalidate
        >
          <!-- Google Form-linked fields: `name` matches Sheets columns via entry.* ids -->
          <input type="hidden" name={ictoGoogleFormEntries.serviceType} id="ict-service-type" value="" />
          <input type="hidden" name={ictoGoogleFormEntries.localRecordId} id="ict-gf-local-record-id" value="" autocomplete="off" />
          <input type="hidden" name={ictoGoogleFormEntries.appointmentReference} id="ict-gf-appointment-reference" value="" />
          <input type="hidden" name={ictoGoogleFormEntries.requesterInformation} id="ict-gf-requester-information" value="" />
          <input type="hidden" name={ictoGoogleFormEntries.validIdFront} id="ict-gf-valid-id-front" value="" autocomplete="off" />
          <input type="hidden" name={ictoGoogleFormEntries.validIdBack} id="ict-gf-valid-id-back" value="" autocomplete="off" />
          <input type="hidden" name={ictoGoogleFormEntries.certificateOfRegistrationCor} id="ict-gf-cor" value="" autocomplete="off" />
          <input type="hidden" name={ictoGoogleFormEntries.hardwareAndTechnicalAssistance} id="ict-gf-hardware-block" value="" autocomplete="off" />
          <input type="hidden" name={ictoGoogleFormEntries.softwareInstallation} id="ict-gf-software-block" value="" autocomplete="off" />
          <input type="hidden" name={ictoGoogleFormEntries.liabilityDisclaimer} id="ict-gf-liability" value="" autocomplete="off" />
          <input type="hidden" name={ictoGoogleFormEntries.approveHandwritten} id="ict-gf-approve-handwritten" value="" autocomplete="off" />
          <input type="hidden" name={ictoGoogleFormEntries.eSignature} id="ict-gf-esignature" value="" autocomplete="off" />
          <input type="hidden" name={ictoGoogleFormEntries.captureAt} id="ict-gf-capture-at" value="" autocomplete="off" />
          <input
            type="text"
            id="ict-hp-company-url"
            name="hp_company_url"
            tabindex="-1"
            autocomplete="off"
            class="sr-only"
            aria-hidden="true"
            value=""
          />

          <div
            id="icto-network-banner"
            class="hidden mx-6 sm:mx-8 mt-6 rounded-xl border border-amber-300/90 bg-amber-50 px-4 py-3.5 text-sm shadow-sm dark:border-amber-700/50 dark:bg-amber-950/35"
            role="status"
            aria-live="polite"
            aria-atomic="true"
          >
