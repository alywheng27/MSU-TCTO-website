          ) {
            checkedServices.push(cb.name);
          }
        });

        const roleRaw = valRole();
        var requesterType = '';
        if (roleRaw === 'student') requesterType = 'Student';
        else if (roleRaw === 'faculty') requesterType = 'Faculty';
        else if (roleRaw === 'staff') requesterType = 'Staff';

        var serviceType = '';
        const selectedServiceRaw =
          (form.getAttribute('data-selected-service') || '').trim() || gField('serviceType');
        const st = selectedServiceRaw;
        if (st === 'emergency') serviceType = 'Emergency';
        else if (st === 'major') serviceType = 'Major';
        else if (st === 'routine') serviceType = 'Routine';
        const statusLabel = st === 'emergency' ? 'For Triage' : 'Pending';
        const priorityLevel =
          st === 'emergency' ? 'High' : 'Low';
        const sourceLabel = 'Form';

        const remarksCore = gField('remarksAdditionalDetailsOptional');
        const metaLine =
          checkedServices.length > 0
            ? '\n\n[Selected categories: ' + checkedServices.join(', ') + ']'
            : '';

        var submissionId =
          typeof crypto !== 'undefined' && crypto.randomUUID
            ? crypto.randomUUID()
            : 'WEB-' + String(Date.now());
        const portalRemarkMeta = 'Portal submission ID: ' + submissionId + '.\n';

        const uploadParts = [];
        var sn;
        sn = uploadedFileName('student_id_front');
        if (sn) uploadParts.push('student_id_front=' + sn);
        sn = uploadedFileName('student_id_back');
        if (sn) uploadParts.push('student_id_back=' + sn);
        sn = uploadedFileName('student_cor_file');
        if (sn) uploadParts.push('student_cor=' + sn);
        sn = uploadedFileName('staff_faculty_id_front');
        if (sn) uploadParts.push('staff_faculty_id_front=' + sn);
        sn = uploadedFileName('staff_faculty_id_back');
        if (sn) uploadParts.push('staff_faculty_id_back=' + sn);
        const uploadMeta =
          uploadParts.length > 0
            ? '\n\n[Filenames submitted with form (upload on web only): ' + uploadParts.join('; ') + ']'
            : '';

        const requestingPersonVal = gField('requestingPerson');
        var requestEmailVal = gField('institutionalOfficialEmail');
        const officeVal = gField('collegeOrOffice');
        const locationVal = gField('locationOrWorkLocation');
        const hwSpecificText = gField('specificHardware');
        const liabilityOn = !!form.querySelector('#liability-ack:checked');
        const esignAckOn = !!form.querySelector('#ict-esign-ack:checked');
        var printedSignatoryName = gField('printedName');
        var sigJpeg =
          typeof window.__ictSigExportJpeg === 'function' ? window.__ictSigExportJpeg() : '';
        if (!sigJpeg) sigJpeg = '';
        var titleLine = serviceType ? serviceType + ' — ' + (requestingPersonVal || 'Request') : requestingPersonVal || 'ICT Service Request';
        const submittedIso = new Date().toISOString();

        /** camelCase — matches usual HTTP-trigger JSON schema samples */
        const hwComput = checkedLabel('hw_computer');
        const hwNet = checkedLabel('hw_network');
        const hwPrint = checkedLabel('hw_printer');
        const hwReplace = checkedLabel('hw_replacement');

        const studentFront = uploadedFileName('student_id_front');
        const studentBack = uploadedFileName('student_id_back');
        const corNm = uploadedFileName('student_cor_file');
        const staffIdFrontNm = uploadedFileName('staff_faculty_id_front');
        const staffIdBackNm = uploadedFileName('staff_faculty_id_back');

        const requestRecord = {
          ServiceType: serviceType,
          RequesterType: requesterType,
          RequestingPerson: requestingPersonVal,
          RequesterPerson: requestingPersonVal,
          OfficeOrCollege: officeVal,
          OfficeorCollege: officeVal,
          Location: locationVal,
          RequesterEmail: requestEmailVal,
          PrintedSignatoryName: printedSignatoryName || '',
          AppointmentReference: appointmentReference,
          Status: statusLabel,
          Priority: priorityLevel,
          Source: sourceLabel,
        };

        const sharePointItem = {
          ServiceType: { Value: serviceType || '' },
          RequesterType: { Value: requesterType || '' },
          RequestingPerson: requestingPersonVal || '',
          OfficeOrCollege: officeVal || '',
          Location: locationVal || '',
          RequesterEmail: requestEmailVal || '',
          AppointmentReference: appointmentReference || '',
          LiabilityAccepted: liabilityOn,
          ElectronicSignatureAcknowledged: esignAckOn,
          ElectronicSignaturePresent: !!sigJpeg,
          PrintedSignatoryName: printedSignatoryName || '',
          TypedAttestation: printedSignatoryName || '',
          Status: { Value: statusLabel || '' },
          Priority: { Value: priorityLevel || '' },
          SubmittedAt: new Date().toLocaleDateString('en-US'),
          Source: { Value: sourceLabel || '' },
          HardwareSpecific: !!(
            hwSpecificText ||
            hwComput ||
            hwNet ||
            hwPrint ||
            hwReplace ||
            checkedLabel('hw_install')
          ),
          HW_ComputerLaptopTroubleshooting: hwComput,
          HW_NetworkCablingPhysical: hwNet,
          HW_PrinterScannerIssues: hwPrint,
          HW_HardwareReplacementUpgrades: hwReplace,
          HW_HardwareInstallationSetup: checkedLabel('hw_install'),
          SW_SoftwareInstallation: checkedLabel('sw_install'),
          SW_LicenseActivationTroubleshoot: checkedLabel('sw_license'),
          SW_SoftwareUpdatesPatches: checkedLabel('sw_updates'),
          SW_SystemReinstallRecovery: checkedLabel('sw_reinstall'),
          SW_AccountConfigLoginAssist: checkedLabel('sw_account'),
          SW_UserAccessPermissions: checkedLabel('sw_access'),
          SW_OnlineTools: checkedLabel('sw_online'),
          StudentIDFron: studentFront || '',
          StudentIDBack: studentBack || '',
          CORFile: corNm || '',
        };

        return {
          submissionId: submissionId,
          SubmissionId: submissionId,

          appointmentReference: appointmentReference,
          AppointmentReference: appointmentReference,

          title: titleLine,
          Title: titleLine,

          serviceType: serviceType,
          ServiceType: serviceType,

          requesterType: requesterType,
          RequesterType: requesterType,

          requestingPerson: requestingPersonVal,
          RequestingPerson: requestingPersonVal,
          requesterPerson: requestingPersonVal,
          RequesterPerson: requestingPersonVal,

          officeOrCollege: officeVal,
          OfficeOrCollege: officeVal,
          officeorCollege: officeVal,
          OfficeorCollege: officeVal,

          location: locationVal,
          Location: locationVal,

          requesterEmail: requestEmailVal,
          RequesterEmail: requestEmailVal,

          liabilityAccepted: liabilityOn,
          LiabilityAccepted: liabilityOn,

          electronicSignatureImage: sigJpeg,
          ElectronicSignatureImage: sigJpeg,
          printedSignatoryName: printedSignatoryName,
          PrintedSignatoryName: printedSignatoryName,
          typedSignatureAttestation: printedSignatoryName,
          TypedSignatureAttestation: printedSignatoryName,
          electronicSignatureAcknowledged: esignAckOn,
          ElectronicSignatureAcknowledged: esignAckOn,
          signatureRecordedAt: submittedIso,
          SignatureRecordedAt: submittedIso,

          status: statusLabel,
          Status: statusLabel,

          priority: priorityLevel,
          Priority: priorityLevel,

          submittedAt: submittedIso,
          SubmittedAt: submittedIso,

          requestDate: gField('date'),
          RequestDate: gField('date'),

          source: sourceLabel,
          Source: sourceLabel,

          fields: requestRecord,
          Fields: requestRecord,
          item: sharePointItem,
          Item: sharePointItem,

          hardwareSpecific: hwSpecificText,
          HardwareSpecific: hwSpecificText,

          softwareSpecific: gField('specificSoftware'),
          SoftwareSpecific: gField('specificSoftware'),

          otherServices: gField('otherServices'),
          OtherServices: gField('otherServices'),

          /** Full audit blob for integrations; Google `entry.*` remarks use textarea only (`requesterRemarksPlain`). */
          requesterRemarks: portalRemarkMeta + remarksCore + metaLine + uploadMeta,
          RequesterRemarks: portalRemarkMeta + remarksCore + metaLine + uploadMeta,
          requesterRemarksPlain: remarksCore,
          RequesterRemarksPlain: remarksCore,

          hardware: {
            computerLaptopTroubleshooting: hwComput,
            networkCablingPhysical: hwNet,
            printerScannerIssues: hwPrint,
            hardwareReplacementUpgrades: hwReplace,
          },
          Hardware: {
            ComputerLaptopTroubleshooting: hwComput,
            NetworkCablingPhysical: hwNet,
            PrinterScannerIssues: hwPrint,
            HardwareReplacementUpgrades: hwReplace,
          },

          computerLaptopTroubleshooting: hwComput,
          networkCablingPhysical: hwNet,
          printerScannerIssues: hwPrint,
          hardwareReplacementUpgrades: hwReplace,

          ComputerLaptopTroubleshooting: hwComput,
          NetworkCablingPhysical: hwNet,
          PrinterScannerIssues: hwPrint,
          HardwareReplacementUpgrades: hwReplace,

          studentIdFront: studentFront,
          studentIdBack: studentBack,
          corFile: corNm,
          staffFacultyIdFront: staffIdFrontNm,
          staffFacultyIdBack: staffIdBackNm,
          StudentIDFront: studentFront,
          StudentIDBack: studentBack,
          CORFile: corNm,
          StaffFacultyIdFront: staffIdFrontNm,
          StaffFacultyIdBack: staffIdBackNm,
        };
      }

      function resetIctoServiceFormAfterSuccess() {
        if (!form) return;
        try {
          form.reset();
        } catch (eReset) {}
        form.removeAttribute('data-selected-service');
        form.removeAttribute('data-sig-has-ink');
        if (hiddenType) hiddenType.value = '';
        var sigClearBtn = document.getElementById('ict-sig-clear');
        if (sigClearBtn) {
          try {
            sigClearBtn.click();
          } catch (eClr) {}
        }
        if (humanVerifyChk) {
          try {
            humanVerifyChk.dispatchEvent(new Event('change', { bubbles: true }));
          } catch (eHv) {}
        }
        toggleDocumentRequirements();
        updateRequesterFieldLabels();
        syncSubmitAvailability();
      }

      form.addEventListener('submit', function (e) {
        e.preventDefault();
        syncSubmitAvailability();
        const selectedService =
          (form.getAttribute('data-selected-service') || '').trim() || gField('serviceType');
        if (!selectedService) return;
        if (!form.reportValidity()) {
          var firstInv = form.querySelector(':invalid');
          if (firstInv && typeof firstInv.scrollIntoView === 'function') {
            try {
              firstInv.scrollIntoView({ behavior: 'smooth', block: 'center' });
            } catch (eScrollInv) {
              /* ignore */
            }
          }
          if (humanVerifyWrap && humanVerifyChk && firstInv === humanVerifyChk) {
            humanVerifyWrap.classList.remove('icto-human-verify--shake');
            void humanVerifyWrap.offsetWidth;
            humanVerifyWrap.classList.add('icto-human-verify--shake');
            window.setTimeout(function () {
              humanVerifyWrap.classList.remove('icto-human-verify--shake');
            }, 520);
          }
          if (captchaWrap && captchaInput && firstInv === captchaInput) {
            showInlineCaptchaError('Please enter the generated security code.');
            captchaWrap.scrollIntoView({ behavior: 'smooth', block: 'center' });
          }
          return;
        }
        if (humanVerifyChk && humanVerifyChk.checked && !isInlineCaptchaValid()) {
          captchaFailedAttempts += 1;
          if (captchaInput) {
            captchaInput.setCustomValidity('Please enter the correct security code.');
            captchaInput.reportValidity();
            captchaInput.setCustomValidity('');
          }
          var attemptsLeft = CAPTCHA_MAX_ATTEMPTS - captchaFailedAttempts;
          if (captchaFailedAttempts >= CAPTCHA_MAX_ATTEMPTS) {
            renderInlineCaptchaCode(
              'Maximum attempts reached. A new security code was generated.'
            );
            showInlineCaptchaError(
              'Maximum attempts reached. A new code has been generated; please try again.'
            );
          } else {
            showInlineCaptchaError(
              'Incorrect code. ' + attemptsLeft + ' attempt(s) remaining before auto-refresh.'
            );
          }
          updateInlineCaptchaMeta();
          if (captchaWrap) {
            captchaWrap.classList.remove('icto-human-verify--shake');
            void captchaWrap.offsetWidth;
            captchaWrap.classList.add('icto-human-verify--shake');
            captchaWrap.scrollIntoView({ behavior: 'smooth', block: 'center' });
            window.setTimeout(function () {
              captchaWrap.classList.remove('icto-human-verify--shake');
            }, 520);
          }
          return;
        }
        if (typeof window.__ictSigIsComplete === 'function' && !window.__ictSigIsComplete()) {
          window.alert(
            'Electronic signature required: draw your signature on the pad and enter your printed name below it in the Electronic signature section.'
          );
          var pn = document.getElementById('ict-printed-name');
          var wrapSig = document.getElementById('ict-signature-wrap');
          if (wrapSig && form.getAttribute('data-sig-has-ink') !== '1') {
            wrapSig.scrollIntoView({ behavior: 'smooth', block: 'center' });
          } else if (pn && !String(pn.value || '').trim()) {
            pn.focus();
          } else if (wrapSig) {
            wrapSig.scrollIntoView({ behavior: 'smooth', block: 'center' });
          }
          return;
        }
        const submitButton = submitButtonEl || form.querySelector('button[type="submit"]');
        if (submitButton) submitButton.setAttribute('disabled', 'disabled');

        if (val('hp_company_url')) {
          if (submitButton) submitButton.removeAttribute('disabled');
          return;
        }

        function runServiceRequestSubmission() {
          var appointmentReference = generateAppointmentReference();
          var payload = collectRequestPayload(appointmentReference);

          function finishIctoUiAfterSubmit() {
            populateIctoReceipt(payload);
            if (modal && modal.classList.contains('is-open')) {
              closeFormModal();
            }
            resetIctoServiceFormAfterSuccess();
            openIctoReceiptModal();
            if (submitButton) submitButton.removeAttribute('disabled');
          }

          if (typeof window !== 'undefined' && window.__ICTO_SHEET_INGEST_ENABLED) {
            openIctoSubmitProcessingOverlay();
            getIctoRecaptchaToken('icto_service_submit')
              .then(function (recaptchaToken) {
                return mirrorSubmissionToSheetIngest(payload, appointmentReference, recaptchaToken);
              })
              .then(function () {
                closeIctoSubmitProcessingOverlay();
                setTimeout(function () {
                  finishIctoUiAfterSubmit();
                }, 220);
              })
              .catch(function (err) {
                closeIctoSubmitProcessingOverlay();
                var msg =
                  err && err.message ? String(err.message) : 'Please try again or contact ICTO.';
                openIctoIntakeErrorModal(msg);
                if (submitButton) submitButton.removeAttribute('disabled');
              });
            return;
          }

          openIctoSubmitProcessingOverlay();
          requestAnimationFrame(function () {
            requestAnimationFrame(function () {
              mirrorSubmissionToGoogleForm(payload, appointmentReference);
              window.setTimeout(function () {
                closeIctoSubmitProcessingOverlay();
                window.setTimeout(function () {
                  finishIctoUiAfterSubmit();
                }, 220);
              }, 520);
            });
          });
        }

        if (typeof navigator !== 'undefined' && navigator.onLine === false) {
          ictoNetReachable = false;
          updateIctoNetworkBanner();
          if (submitButton) submitButton.removeAttribute('disabled');
          openIctoNetworkModal(
            'offline',
            'Your device reports no internet connection. Connect to Wi‑Fi or mobile data, then submit again.'
          );
          return;
        }

        ictoPingServer().then(function (ok) {
          ictoNetReachable = ok;
          updateIctoNetworkBanner();
          if (!ok) {
            if (submitButton) submitButton.removeAttribute('disabled');
            openIctoNetworkModal(
              'unstable',
              'We could not reach the portal (timed out or no response). Your link may be unstable — try again in a moment.'
            );
            return;
          }
          runServiceRequestSubmission();
        });
      });
    })();
  </script>

  <script is:inline>
    (function () {
      var root = document.getElementById('icto-team-photo-modal');
      var img = document.getElementById('icto-team-photo-img');
      var titleEl = document.getElementById('icto-team-photo-title');
      var roleEl = document.getElementById('icto-team-photo-role');
      var panel = root ? root.querySelector('.icto-team-photo-panel') : null;
      if (!root || !img || !titleEl || !roleEl) return;

      var lastFocus = null;

      function otherIctoOverlaysOpen() {
        var form = document.getElementById('icto-form-modal');
        var rec = document.getElementById('icto-receipt-modal');
        var proc = document.getElementById('icto-submit-processing');
        return (
          (form && form.classList.contains('is-open')) ||
          (rec && rec.classList.contains('is-open')) ||
          (proc && proc.classList.contains('is-open'))
        );
      }

      function releaseBodyScrollIfSafe() {
        if (!otherIctoOverlaysOpen()) document.body.classList.remove('overflow-hidden');
      }

      function openTeamPhotoModal(src, title, role) {
        if (!src) return;
        lastFocus = document.activeElement;
        img.src = src;
        img.alt = title ? 'Portrait of ' + title : 'Portrait';
        titleEl.textContent = title || '\u2014';
        roleEl.textContent = role || '\u2014';
        root.classList.remove('hidden');
        root.setAttribute('aria-hidden', 'false');
        void root.offsetWidth;
        root.classList.add('is-open');
        document.body.classList.add('overflow-hidden');
        setTimeout(function () {
          var closeBtn = document.getElementById('icto-team-photo-close');
          if (closeBtn && closeBtn.focus) closeBtn.focus();
          else if (panel && panel.focus) panel.focus();
        }, 90);
      }

      function closeTeamPhotoModal() {
        root.classList.remove('is-open');
        root.setAttribute('aria-hidden', 'true');
        setTimeout(function () {
          if (!root.classList.contains('is-open')) {
            root.classList.add('hidden');
            img.removeAttribute('src');
            img.alt = '';
          }
        }, 280);
        releaseBodyScrollIfSafe();
        if (lastFocus && typeof lastFocus.focus === 'function') {
          try {
            lastFocus.focus();
          } catch (er) {}
          lastFocus = null;
        }
      }

      document.addEventListener(
        'keydown',
        function (e) {
          if (e.key !== 'Escape') return;
          if (!root.classList.contains('is-open')) return;
          e.preventDefault();
          e.stopPropagation();
          closeTeamPhotoModal();
        },
        true
      );

      var org = document.querySelector('.icto-team-org');
      if (org) {
        org.addEventListener('click', function (e) {
          var trigger = e.target.closest('[data-icto-team-photo-src]');
          if (!trigger) return;
          var src = trigger.getAttribute('data-icto-team-photo-src');
          if (!src) return;
          e.preventDefault();
          openTeamPhotoModal(
            src,
            trigger.getAttribute('data-icto-team-photo-title') || '',
            trigger.getAttribute('data-icto-team-photo-role') || ''
          );
        });
      }

      root.querySelectorAll('[data-close-team-photo]').forEach(function (node) {
        node.addEventListener('click', function (e) {
          e.preventDefault();
          closeTeamPhotoModal();
        });
      });
    })();
  </script>

