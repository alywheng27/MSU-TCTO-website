                      <svg class="ict-form-stepper-svg ict-form-stepper-svg--check" viewBox="0 0 24 24" fill="none" focusable="false">
                        <path d="M20 6L9 17l-5-5" stroke="currentColor" stroke-width="2.25" stroke-linecap="round" stroke-linejoin="round"></path>
                      </svg>
                      <svg class="ict-form-stepper-svg ict-form-stepper-svg--x" viewBox="0 0 24 24" fill="none" focusable="false">
