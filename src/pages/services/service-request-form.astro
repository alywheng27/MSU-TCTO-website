      /** Word-wrap for canvas `fillText` (spaces; long tokens split by character if needed). */
      function ictoCanvasWrapLines(ctx, text, maxWidth) {
        var s = String(text == null ? '' : text).replace(/\r/g, '');
        var paras = s.split('\n');
        /** @type {string[]} */
        var out = [];
        for (var pi = 0; pi < paras.length; pi++) {
          var words = paras[pi].split(/\s+/).filter(function (w) {
            return w.length > 0;
          });
          var line = '';
          for (var wi = 0; wi < words.length; wi++) {
            var w = words[wi];
            var test = line ? line + ' ' + w : w;
            if (ctx.measureText(test).width <= maxWidth) {
              line = test;
              continue;
            }
            if (line) out.push(line);
            if (ctx.measureText(w).width <= maxWidth) {
              line = w;
            } else {
              var chunk = '';
              for (var ci = 0; ci < w.length; ci++) {
                var t2 = chunk + w[ci];
                if (ctx.measureText(t2).width > maxWidth && chunk) {
                  out.push(chunk);
                  chunk = w[ci];
                } else {
                  chunk = t2;
                }
              }
              line = chunk;
            }
          }
          if (line) out.push(line);
          if (pi < paras.length - 1) out.push('');
        }
        return out.length ? out : [''];
      }

      /** Renders current receipt DOM values to a JPEG blob (no external libs). */
      function ictoBuildReceiptJpegBlob(done) {
        var ref = ictoReceiptTextById('icto-receipt-ref');
        var rows = [
          ['Service type', ictoReceiptTextById('icto-receipt-service')],
          ['Requester', ictoReceiptTextById('icto-receipt-person')],
          ['Role', ictoReceiptTextById('icto-receipt-role')],
          ['Date (form)', ictoReceiptTextById('icto-receipt-date')],
          ['Printed name', ictoReceiptTextById('icto-receipt-printed')],
          ['Email', ictoReceiptTextById('icto-receipt-email')],
          ['Office / college', ictoReceiptTextById('icto-receipt-office')],
          ['Location', ictoReceiptTextById('icto-receipt-location')],
        ];
        var dateline = ictoReceiptTextById('icto-receipt-dateline');
        var foot = ictoReceiptTextById('icto-receipt-system-id');

        var W = 900;
        var pad = 36;
        var inner = W - pad * 2;
        var headerH = 118;
        var bannerH = 56;
        var sans =
          '"Segoe UI", system-ui, -apple-system, Roboto, "Helvetica Neue", Arial, sans-serif';
        var mono = 'ui-monospace, Consolas, "Courier New", monospace';

        function lineHeightPx(size) {
          return Math.round(size * 1.35);
        }

        var mEl = document.createElement('canvas');
        var m = mEl.getContext('2d');
        if (!m) {
          done(null);
          return;
        }

        m.font = 'bold 26px ' + mono;
        var refLines = ictoCanvasWrapLines(m, ref, inner);
        m.font = '12px ' + sans;
        var dateLines = ictoCanvasWrapLines(m, dateline, inner);
        /** @type {string[][]} */
        var valLinesList = [];
        for (var i = 0; i < rows.length; i++) {
          m.font = '14px ' + sans;
          valLinesList.push(ictoCanvasWrapLines(m, rows[i][1], inner));
        }
        m.font = '11px ' + sans;
        var footLines = foot && foot !== '\u2014' ? ictoCanvasWrapLines(m, foot, inner) : [];

        var yMes = headerH + pad + bannerH + 18;
        yMes += 20;
        var mi;
        for (mi = 0; mi < refLines.length; mi++) {
          yMes +=
            refLines[mi] === ''
              ? Math.round(lineHeightPx(26) * 0.5)
              : lineHeightPx(26);
        }
        yMes += 6;
        for (mi = 0; mi < dateLines.length; mi++) {
          yMes +=
            dateLines[mi] === ''
              ? lineHeightPx(12) * 0.4
              : lineHeightPx(12);
        }
        yMes += 16 + 18;
        for (var rrM = 0; rrM < rows.length; rrM++) {
          yMes += 16;
          var vlM = valLinesList[rrM];
          for (mi = 0; mi < vlM.length; mi++) {
            yMes +=
              vlM[mi] === '' ? lineHeightPx(14) * 0.35 : lineHeightPx(14);
          }
          yMes += 10;
        }
        if (footLines.length) {
          yMes += 8 + 14;
          for (mi = 0; mi < footLines.length; mi++) {
            yMes +=
              footLines[mi] === '' ? lineHeightPx(11) * 0.35 : lineHeightPx(11);
          }
        }
        yMes += pad;
        var H = Math.max(620, Math.ceil(yMes));

        var canvas = document.createElement('canvas');
        canvas.width = W;
        canvas.height = H;
        var ctx = canvas.getContext('2d');
        if (!ctx) {
          done(null);
          return;
        }

        function paintHeader() {
          var grd = ctx.createLinearGradient(0, 0, W, 0);
          grd.addColorStop(0, '#61063b');
          grd.addColorStop(0.5, '#4d052f');
          grd.addColorStop(1, '#61063b');
          ctx.fillStyle = grd;
          ctx.fillRect(0, 0, W, headerH);
          ctx.fillStyle = 'rgba(255,255,255,0.14)';
          for (var gx = 0; gx < W; gx += 40) ctx.fillRect(gx, 0, 1, headerH);
        }

        function fillRoundRect(x, y0, w, h0, r0) {
          ctx.beginPath();
          if (typeof ctx.roundRect === 'function') {
            ctx.roundRect(x, y0, w, h0, r0);
          } else {
            ctx.rect(x, y0, w, h0);
          }
        }

        paintHeader();
        ctx.fillStyle = '#ffffff';
        ctx.fillRect(0, headerH, W, H - headerH);

        ctx.fillStyle = '#ffffff';
        ctx.globalAlpha = 0.82;
        ctx.font = 'bold 11px ' + sans;
        ctx.fillText('MINDANAO STATE UNIVERSITY \u2014 TCTO', pad, 34);
        ctx.globalAlpha = 1;
        ctx.font = 'bold 24px ' + sans;
        ctx.fillText('ICTO submission receipt', pad, 62);
        ctx.globalAlpha = 0.92;
        ctx.font = '14px ' + sans;
        ctx.fillText('Official reference for inquiries at the ICT Office.', pad, 86);
        ctx.globalAlpha = 1;

        var py = headerH + pad;
        ctx.fillStyle = '#ecfdf5';
        ctx.strokeStyle = '#a7f3d0';
        ctx.lineWidth = 1;
        fillRoundRect(pad - 8, py - 8, inner + 16, bannerH, 10);
        ctx.fill();
        ctx.stroke();
        ctx.font = 'bold 14px ' + sans;
        ctx.fillStyle = '#065f46';
        ctx.fillText('Successfully submitted', pad + 8, py + 22);
        py += bannerH + 18;

        ctx.font = 'bold 10px ' + sans;
        ctx.fillStyle = '#61063b';
        ctx.fillText('APPOINTMENT REFERENCE', pad, py);
        py += 20;

        ctx.font = 'bold 26px ' + mono;
        ctx.fillStyle = '#61063b';
        var li;
        for (li = 0; li < refLines.length; li++) {
          if (refLines[li] === '') {
            py += Math.round(lineHeightPx(26) * 0.5);
          } else {
            ctx.fillText(refLines[li], pad, py);
            py += lineHeightPx(26);
          }
        }
        py += 6;

        ctx.font = '12px ' + sans;
        ctx.fillStyle = '#64748b';
        for (li = 0; li < dateLines.length; li++) {
          if (dateLines[li] === '') py += lineHeightPx(12) * 0.4;
          else {
            ctx.fillText(dateLines[li], pad, py);
            py += lineHeightPx(12);
          }
        }
        py += 16;

        ctx.strokeStyle = '#e2e8f0';
        ctx.beginPath();
        ctx.moveTo(pad, py);
        ctx.lineTo(pad + inner, py);
        ctx.stroke();
        py += 18;

        for (var rr = 0; rr < rows.length; rr++) {
          ctx.font = 'bold 10px ' + sans;
          ctx.fillStyle = '#64748b';
          ctx.fillText(rows[rr][0].toUpperCase(), pad, py);
          py += 16;
          ctx.font = '14px ' + sans;
          ctx.fillStyle = '#0f172a';
          var vl = valLinesList[rr];
          for (li = 0; li < vl.length; li++) {
            if (vl[li] === '') py += lineHeightPx(14) * 0.35;
            else {
              ctx.fillText(vl[li], pad, py);
              py += lineHeightPx(14);
            }
          }
          py += 10;
        }

        if (footLines.length) {
          py += 8;
          ctx.strokeStyle = '#e2e8f0';
          ctx.beginPath();
          ctx.moveTo(pad, py);
          ctx.lineTo(pad + inner, py);
          ctx.stroke();
          py += 14;
          ctx.font = '11px ' + sans;
          ctx.fillStyle = '#64748b';
          for (li = 0; li < footLines.length; li++) {
            if (footLines[li] === '') py += lineHeightPx(11) * 0.35;
            else {
              ctx.fillText(footLines[li], pad, py);
              py += lineHeightPx(11);
            }
          }
        }

        canvas.toBlob(
          function (blob) {
            done(blob || null);
          },
          'image/jpeg',
          0.92
        );
      }

      function safeIctoReceiptDownloadBasename(refText) {
        var s = String(refText || '').replace(/\u2014/g, '').trim();
        s = s.replace(/[^a-zA-Z0-9._-]+/g, '-').replace(/^-+|-+$/g, '');
        return s ? s : 'receipt';
      }

