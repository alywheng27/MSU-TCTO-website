---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar';
import FooterNav from '../../components/FooterNav.astro';
import Footer from '../../components/Footer.astro';
import '../../styles/css/global.css';

const currentPath = Astro.url.pathname;
const pageTitle = 'ICT Service Request | MSU-TCTO ICTO';
/**
 * Programmatic POST target (`…/formResponse`). In Google Forms: Send → link icon → use the submit URL ending in `/formResponse`.
 * Prefer overriding in hosting env: `PUBLIC_ICTO_GOOGLE_FORM_ACTION` (e.g. Netlify/Vite).
 */
const ictoGoogleFormAction =
  (import.meta.env.PUBLIC_ICTO_GOOGLE_FORM_ACTION as string | undefined)?.trim() ||
  'https://docs.google.com/forms/u/0/d/e/1FAIpQLScpAlvJbQaoSKjFcRbL9PCJ92nK6cT-aYnflI3aViikJEr-MQ/formResponse';

/**
 * Form revision id (`fbzx` in native POST). Update if Google shows a blank row after programmatic submit.
 */
const ictoGoogleFormFbzx =
  (import.meta.env.PUBLIC_ICTO_GOOGLE_FORM_FBZX as string | undefined)?.trim() ||
  '4324897675543393794';

/**
 * Multi-section forms need comma-separated indexes (e.g. `0,1`). This ICTO Form is single-page — live HTML uses `0` only.
 * Override via `PUBLIC_ICTO_GOOGLE_FORM_PAGE_HISTORY` if the linked form gains sections.
 */
const ictoGoogleFormPageHistory =
  (import.meta.env.PUBLIC_ICTO_GOOGLE_FORM_PAGE_HISTORY as string | undefined)?.trim() || '0';

/**
 * When `true`, submissions POST to `/api/icto-service-sheet-ingest` (Netlify/Astro server), which forwards
 * to Google Apps Script and appends Sheet + Drive — avoids HTTP 401 on direct `docs.google.com` POST.
 * Server env also required: `ICTO_APPS_SCRIPT_INGEST_URL`, `ICTO_SERVICE_SHEET_SHARED_SECRET`.
 */
const ictoSheetIngestEnabled =
  (import.meta.env.PUBLIC_ICTO_SERVICE_SHEET_INGEST as string | undefined)?.trim() === 'true';
const ictoRecaptchaSiteKey =
  (import.meta.env.PUBLIC_RECAPTCHA_SITE_KEY as string | undefined)?.trim() || '';
const ictoCaptchaTtlSeconds =
  (import.meta.env.PUBLIC_ICTO_CAPTCHA_TTL_SECONDS as string | undefined)?.trim() || '60';
const ictoCaptchaMaxAttempts =
  (import.meta.env.PUBLIC_ICTO_CAPTCHA_MAX_ATTEMPTS as string | undefined)?.trim() || '3';

/** Logical field keys → Google `entry.*` names (single source of truth for HTML `name` + scripts). */
/* Must match the linked Google Form / Sheet “Form responses” headers. If `entry.*` drift, wrong columns or blanks in Sheets. */
const ictoGoogleFormEntries = {
  serviceType: 'entry.1331424977',
  localRecordId: 'entry.828831792',
  appointmentReference: 'entry.975653240',
  requesterInformation: 'entry.1249583395',
  date: 'entry.467064022',
  requestingPerson: 'entry.1006588440',
  institutionalOfficialEmail: 'entry.1568275743',
  collegeOrOffice: 'entry.417872517',
  locationOrWorkLocation: 'entry.1245989223',
  validIdFront: 'entry.1206927332',
  validIdBack: 'entry.1249099390',
  certificateOfRegistrationCor: 'entry.449553907',
  hardwareAndTechnicalAssistance: 'entry.1740815378',
  specificHardware: 'entry.745277336',
  softwareInstallation: 'entry.1567012588',
  specificSoftware: 'entry.83656928',
  otherServices: 'entry.2091070010',
  liabilityDisclaimer: 'entry.1619525607',
  /** ApproveHandwritten (multiple choice) — option text must match Google Form exactly (e.g. YES). */
  approveHandwritten: 'entry.1382839950',
  remarksAdditionalDetailsOptional: 'entry.1556705629',
  eSignature: 'entry.1605280317',
  captureAt: 'entry.1393461297',
  printedName: 'entry.244210367',
};

/**
 * Must match row 1 of the linked responses tab (same text Google puts in the Sheet).
 * “Timestamp” is filled by ingest, not mapped here. If you fix a typo in the Form (e.g. Collgeof → College), update this object to match.
 */
const ictoFormResponseColumnTitles = {
  serviceType: 'Service Type',
  localRecordId: 'Local record ID',
  appointmentReference: 'Appointment Reference',
  requesterInformation: 'Requester Information',
  date: 'Date',
  requestingPerson: 'Requesting Person',
  institutionalOfficialEmail: 'Institutional / Official Email',
  collegeOrOffice: 'Collgeof/Office',
  locationOrWorkLocation: 'Location/Work Location',
  validIdFront: 'Valid ID (Front)',
  validIdBack: 'Valid ID (Back)',
  certificateOfRegistrationCor: 'Certificate of Registration (COR)',
  hardwareAndTechnicalAssistance: 'Hardware and Technical Assistance',
  specificHardware: 'Specific  (Hardware)',
  softwareInstallation: 'Software Installation',
  specificSoftware: 'Specific (Software)',
  otherServices: 'Other Services',
  liabilityDisclaimer: 'Liability Disclaimer',
  approveHandwritten: 'ApproveHandwritten',
  remarksAdditionalDetailsOptional: 'Remarks / Additional Details (Optional)',
  eSignature: 'e-signature',
  captureAt: 'Capture at',
  printedName: 'Printed Name',
};

/** @type {Record<string, string>} */
const ictoEntryIdByFormResponseHeader = {};
for (const [logicalKey, headerTitle] of Object.entries(ictoFormResponseColumnTitles)) {
  const entryKey = /** @type {Record<string,string>} */ (ictoGoogleFormEntries)[logicalKey];
  if (typeof headerTitle === 'string' && typeof entryKey === 'string')
    ictoEntryIdByFormResponseHeader[headerTitle] = entryKey;
}
/* Alternate row-1 titles (fixed typos etc.) → same entry.* — keeps columns filled if the Sheet differs slightly. */
ictoEntryIdByFormResponseHeader['College/Office'] = ictoGoogleFormEntries.collegeOrOffice;
/** String passed through `define:vars` safely; parsed in-browser so Sheet header ↔ entry ids never corrupt. */
const ictoEntryHeaderMapJson = JSON.stringify(ictoEntryIdByFormResponseHeader);
---

<Layout
  title={pageTitle}
  ogTitle={pageTitle}
  ogDescription="Request creation or password reset of your official MSU-TCTO institutional account through the Information and Communications Technology Office (ICTO)."
>
  <main class="min-h-screen flex flex-col overflow-x-hidden bg-[#61063B] dark:bg-[#61063B]">
    <Navbar path={currentPath} client:load />

    <section
      class="icto-svc-hero relative isolate overflow-hidden rounded-b-[1.75rem] sm:rounded-b-[2.25rem] text-white shadow-[0_28px_80px_-24px_rgba(40,6,28,0.55)]"
    >
      <div
        class="pointer-events-none absolute inset-0 bg-gradient-to-br from-[#3d061d] via-[#61063B] to-[#7c0d4d]"
        aria-hidden="true"
      />
      <div
        class="pointer-events-none absolute inset-0 bg-[radial-gradient(ellipse_100%_80%_at_50%_-30%,rgba(255,255,255,0.14),transparent_50%)]"
        aria-hidden="true"
      />
      <div
        class="pointer-events-none absolute inset-0 bg-[radial-gradient(ellipse_60%_50%_at_100%_50%,rgba(255,182,213,0.12),transparent_45%)]"
        aria-hidden="true"
      />
      <div
        class="absolute inset-0 opacity-[0.11]"
        style="background-image: url('data:image/svg+xml,%3Csvg width=\'60\' height=\'60\' viewBox=\'0 0 60 60\' xmlns=\'http://www.w3.org/2000/svg\'%3E%3Cg fill=\'none\' fill-rule=\'evenodd\'%3E%3Cg fill=\'%23ffffff\' fill-opacity=\'0.5\'%3E%3Cpath d=\'M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z\'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E');"
        aria-hidden="true"
      />
      <div class="pointer-events-none absolute -top-32 -right-20 h-[22rem] w-[22rem] rounded-full bg-gradient-to-br from-white/20 to-transparent blur-3xl" aria-hidden="true" />
      <div class="pointer-events-none absolute -bottom-40 -left-16 h-[20rem] w-[20rem] rounded-full bg-[#2a0418]/60 blur-3xl" aria-hidden="true" />

      <div class="relative z-10 container mx-auto px-4 sm:px-6 lg:px-8 py-14 md:py-20 lg:py-24 max-w-6xl">
        <div id="tour-hero">
        <nav class="mb-8" aria-label="Breadcrumb">
          <ol
            class="inline-flex flex-wrap items-center gap-1.5 rounded-full border border-white/15 bg-white/[0.07] px-3.5 py-2 text-[13px] text-white/85 shadow-[inset_0_1px_0_rgba(255,255,255,0.12)] backdrop-blur-md"
          >
            <li>
              <a href="/" class="hover:text-white transition-colors">Home</a>
            </li>
            <li aria-hidden="true" class="text-white/35">/</li>
            <li>
              <span class="text-white/90">Services</span>
            </li>
            <li aria-hidden="true" class="text-white/35">/</li>
            <li class="font-semibold text-white">ICT service request</li>
          </ol>
        </nav>

        <div
          class="mb-6 inline-flex items-center gap-2 rounded-full border border-white/20 bg-white/10 px-4 py-1.5 text-[11px] font-bold uppercase tracking-[0.22em] text-white/90 shadow-sm backdrop-blur-sm"
        >
          <span class="h-1.5 w-1.5 rounded-full bg-emerald-400 shadow-[0_0_10px_rgba(52,211,153,0.8)]" aria-hidden="true" />
          MSU-TCTO · ICTO official
        </div>

        <p class="text-xs sm:text-sm uppercase tracking-[0.18em] text-white/70 font-semibold">
          Mindanao State University &mdash; Tawi-Tawi College of Technology and Oceanography
        </p>
        <h1 class="mt-4 text-3xl sm:text-4xl md:text-5xl font-bold leading-[1.08] tracking-tight max-w-4xl">
          <span class="font-serif font-bold">Information &amp; Communications Technology Office</span>
          <span class="mt-2 block text-2xl sm:text-3xl md:text-[2.125rem] font-semibold text-white/[0.96] tracking-tight">
            Resource maintenance &amp; service request
          </span>
        </h1>
        <div class="mt-2 h-1 w-16 rounded-full bg-gradient-to-r from-white/60 via-white to-white/40 sm:mt-3 sm:w-20" aria-hidden="true" />
        <p class="mt-6 text-base sm:text-lg text-white/88 max-w-2xl leading-relaxed font-light">
          Request to create or reset a <strong class="font-semibold text-white">MSUTCTO institutional account</strong>, or report ICT
          support needs. <strong class="font-semibold text-white/95">Choose a service type</strong> below to open the official request form.
        </p>
        <p
          class="mt-6 border-l-2 border-white/35 pl-4 text-sm leading-relaxed text-white/80 italic max-w-xl"
        >
          Creating Opportunities, Transforming Lives.
        </p>
        </div>
      </div>
    </section>

    <!-- Service type picker: opens modal form -->
    <section
      id="tour-pick-service"
      class="relative z-[1] -mt-5 flex-1 overflow-hidden bg-gradient-to-b from-slate-100/90 via-slate-50 to-slate-50 py-14 md:py-16 dark:from-[#0a0810] dark:via-[#070b14] dark:to-[#06080f] sm:-mt-6 sm:rounded-t-[1.75rem]"
    >
      <div
        class="pointer-events-none absolute inset-0 bg-[radial-gradient(ellipse_90%_60%_at_50%_0%,rgba(97,6,59,0.07),transparent_55%)] dark:bg-[radial-gradient(ellipse_90%_55%_at_50%_0%,rgba(244,63,134,0.08),transparent_50%)]"
        aria-hidden="true"
      />
      <div
        class="pointer-events-none absolute inset-0 opacity-[0.35] dark:opacity-[0.15]"
        style="background-image: radial-gradient(rgba(15, 23, 42, 0.045) 1px, transparent 1px); background-size: 20px 20px;"
        aria-hidden="true"
      />

      <div class="relative container mx-auto px-4 sm:px-6 lg:px-8 max-w-6xl">
        <div class="mx-auto mb-12 max-w-2xl text-center md:mb-14">
          <p
            class="text-[11px] font-bold uppercase tracking-[0.28em] text-[#61063B] dark:text-rose-300/90 sm:text-xs"
          >
            Step one
          </p>
          <h2 class="mt-3 text-2xl font-bold tracking-tight text-slate-900 dark:text-white sm:text-3xl md:text-[2rem]">
            Choose your service type
          </h2>
          <p class="mx-auto mt-3 max-w-lg text-sm leading-relaxed text-slate-600 dark:text-slate-400 sm:text-base">
            Pick the category that fits your situation. Your selection sets priority context; the full ICTO request form opens in a focused layer so you can finish in one pass.
          </p>
        </div>

        <div class="mx-auto grid max-w-6xl gap-5 sm:grid-cols-3 sm:gap-6 lg:gap-8">
          <button
            type="button"
            class="icto-svc-pick group relative overflow-hidden rounded-3xl border border-[#61063B]/20 bg-white p-7 text-left shadow-[0_4px_6px_-1px_rgba(97,6,59,0.08),0_22px_45px_-24px_rgba(97,6,59,0.2)] ring-1 ring-[#61063B]/10 transition-all duration-500 ease-out before:pointer-events-none before:absolute before:inset-x-0 before:top-0 before:z-[1] before:h-[3px] before:bg-[#61063B] motion-safe:hover:-translate-y-1 hover:border-[#61063B]/40 hover:shadow-[0_28px_55px_-22px_rgba(97,6,59,0.28)] focus:outline-none focus-visible:ring-2 focus-visible:ring-[#61063B]/50 focus-visible:ring-offset-2 dark:border-[#61063B]/25 dark:bg-white dark:ring-[#61063B]/10 dark:hover:border-[#61063B]/40 dark:hover:shadow-[0_28px_55px_-22px_rgba(97,6,59,0.28)] dark:focus-visible:ring-offset-white"
            data-service="emergency"
            aria-describedby="svc-emergency-hint"
          >
            <div
              class="relative z-0 mb-5 flex h-14 w-14 items-center justify-center rounded-2xl bg-white text-[#61063B] shadow-[inset_0_1px_0_rgba(255,255,255,0.75)] ring-1 ring-[#61063B]/25 transition-transform duration-500 motion-safe:group-hover:scale-[1.06] dark:bg-white dark:text-[#61063B] dark:ring-[#61063B]/25"
            >
              <svg class="h-7 w-7" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />
              </svg>
            </div>
            <h3 class="text-lg font-bold tracking-tight text-[#61063B] dark:text-[#61063B]">Emergency</h3>
            <p id="svc-emergency-hint" class="mt-2.5 text-sm leading-relaxed text-[#61063B]/80 dark:text-[#61063B]/80">
              Critical or time-sensitive: outages, security incidents, or work stoppage.
            </p>
            <span
              class="mt-6 inline-flex items-center gap-2 rounded-full bg-white px-3.5 py-2 text-sm font-semibold text-[#61063B] ring-1 ring-[#61063B]/25 transition-all duration-300 group-hover:bg-[#61063B] group-hover:text-white group-hover:shadow-md group-hover:shadow-[#61063B]/25 dark:bg-white dark:text-[#61063B] dark:group-hover:bg-[#61063B] dark:group-hover:text-white"
            >
              Open form
              <svg class="h-4 w-4 translate-x-0 transition-transform duration-300 group-hover:translate-x-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6" />
              </svg>
            </span>
          </button>

          <button
            type="button"
            class="icto-svc-pick group relative overflow-hidden rounded-3xl border border-[#61063B]/20 bg-white p-7 text-left shadow-[0_4px_6px_-1px_rgba(97,6,59,0.08),0_22px_45px_-24px_rgba(97,6,59,0.2)] ring-1 ring-[#61063B]/10 transition-all duration-500 ease-out before:pointer-events-none before:absolute before:inset-x-0 before:top-0 before:z-[1] before:h-[3px] before:bg-[#61063B] motion-safe:hover:-translate-y-1 hover:border-[#61063B]/40 hover:shadow-[0_28px_55px_-22px_rgba(97,6,59,0.28)] focus:outline-none focus-visible:ring-2 focus-visible:ring-[#61063B]/50 focus-visible:ring-offset-2 dark:border-[#61063B]/25 dark:bg-white dark:ring-[#61063B]/10 dark:hover:border-[#61063B]/40 dark:hover:shadow-[0_28px_55px_-22px_rgba(97,6,59,0.28)] dark:focus-visible:ring-offset-white"
            data-service="major"
            aria-describedby="svc-major-hint"
          >
            <div
              class="relative z-0 mb-5 flex h-14 w-14 items-center justify-center rounded-2xl bg-white text-[#61063B] shadow-[inset_0_1px_0_rgba(255,255,255,0.8)] ring-1 ring-[#61063B]/25 transition-transform duration-500 motion-safe:group-hover:scale-[1.06] dark:bg-white dark:text-[#61063B] dark:ring-[#61063B]/25"
            >
              <svg class="h-7 w-7" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10" />
              </svg>
            </div>
            <h3 class="text-lg font-bold tracking-tight text-[#61063B] dark:text-[#61063B]">Major</h3>
            <p id="svc-major-hint" class="mt-2.5 text-sm leading-relaxed text-[#61063B]/80 dark:text-[#61063B]/80">
              Planned work, upgrades, or multi-step projects that need coordination.
            </p>
            <span
              class="mt-6 inline-flex items-center gap-2 rounded-full bg-white px-3.5 py-2 text-sm font-semibold text-[#61063B] ring-1 ring-[#61063B]/25 transition-all duration-300 group-hover:bg-[#61063B] group-hover:text-white group-hover:shadow-md group-hover:shadow-[#61063B]/25 dark:bg-white dark:text-[#61063B] dark:group-hover:bg-[#61063B] dark:group-hover:text-white"
            >
              Open form
              <svg class="h-4 w-4 translate-x-0 transition-transform duration-300 group-hover:translate-x-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6" />
              </svg>
            </span>
          </button>

          <button
            type="button"
            class="icto-svc-pick group relative overflow-hidden rounded-3xl border border-[#61063B]/20 bg-white p-7 text-left shadow-[0_4px_6px_-1px_rgba(97,6,59,0.08),0_22px_45px_-24px_rgba(97,6,59,0.2)] ring-1 ring-[#61063B]/10 transition-all duration-500 ease-out before:pointer-events-none before:absolute before:inset-x-0 before:top-0 before:z-[1] before:h-[3px] before:bg-[#61063B] motion-safe:hover:-translate-y-1 hover:border-[#61063B]/40 hover:shadow-[0_28px_55px_-22px_rgba(97,6,59,0.28)] focus:outline-none focus-visible:ring-2 focus-visible:ring-[#61063B]/50 focus-visible:ring-offset-2 sm:col-auto dark:border-[#61063B]/25 dark:bg-white dark:ring-[#61063B]/10 dark:hover:border-[#61063B]/40 dark:hover:shadow-[0_28px_55px_-22px_rgba(97,6,59,0.28)] dark:focus-visible:ring-offset-white"
            data-service="routine"
            aria-describedby="svc-routine-hint"
          >
            <div
              class="relative z-0 mb-5 flex h-14 w-14 items-center justify-center rounded-2xl bg-white text-[#61063B] shadow-[inset_0_1px_0_rgba(255,255,255,0.9)] ring-1 ring-[#61063B]/25 transition-transform duration-500 motion-safe:group-hover:scale-[1.06] dark:bg-white dark:text-[#61063B] dark:ring-[#61063B]/25"
            >
              <svg class="h-7 w-7" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4" />
              </svg>
            </div>
            <h3 class="text-lg font-bold tracking-tight text-[#61063B] dark:text-[#61063B]">Routine maintenance</h3>
            <p id="svc-routine-hint" class="mt-2.5 text-sm leading-relaxed text-[#61063B]/80 dark:text-[#61063B]/80">
              Standard checklists, scheduled maintenance, and non-urgent support.
            </p>
            <span
              class="mt-6 inline-flex items-center gap-2 rounded-full bg-white px-3.5 py-2 text-sm font-semibold text-[#61063B] ring-1 ring-[#61063B]/25 transition-all duration-300 group-hover:bg-[#61063B] group-hover:text-white group-hover:shadow-md group-hover:shadow-[#61063B]/25 dark:bg-white dark:text-[#61063B] dark:group-hover:bg-[#61063B] dark:group-hover:text-white"
            >
              Open form
              <svg class="h-4 w-4 translate-x-0 transition-transform duration-300 group-hover:translate-x-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6" />
              </svg>
            </span>
          </button>
        </div>
      </div>
    </section>

    <!-- ICTO Team (visual org connector) -->
    <section
      class="relative overflow-hidden bg-white py-14 sm:py-16 dark:bg-[#61063B]"
      aria-labelledby="icto-team-title"
    >
      <div
        class="pointer-events-none absolute inset-0 bg-[radial-gradient(ellipse_80%_65%_at_50%_0%,rgba(97,6,59,0.08),transparent_55%)] dark:bg-[radial-gradient(ellipse_80%_65%_at_50%_0%,rgba(97,6,59,0.16),transparent_50%)]"
        aria-hidden="true"
      />
      <div class="relative container mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
        <div class="mx-auto max-w-2xl text-center">
          <p class="text-[11px] font-bold uppercase tracking-[0.25em] text-[#61063B] dark:text-white">
            ICTO personnel
          </p>
          <h2
            id="icto-team-title"
            class="mt-3 text-2xl font-bold tracking-tight text-[#61063B] dark:text-white sm:text-3xl"
          >
            Our Office Staff
          </h2>
          <p class="mt-3 text-sm leading-relaxed text-[#61063B]/80 dark:text-white/80 sm:text-base">
            The team handling ICT operations, support, and service delivery for MSU-TCTO.
          </p>
          <div class="mt-4 h-1 w-20 rounded-full bg-[#61063B] mx-auto" aria-hidden="true"></div>
        </div>

        <div class="icto-team-org mx-auto mt-10 max-w-6xl rounded-3xl border border-[#61063B]/20 bg-white/90 p-5 shadow-[0_24px_70px_-30px_rgba(97,6,59,0.25)] dark:border-white/25 dark:bg-white sm:p-8 lg:p-10">
          <div class="icto-team-top mx-auto max-w-3xl">
            <div class="icto-team-chancellor flex justify-center pb-5 lg:pb-6">
              <article class="icto-team-card icto-team-card--lead w-full max-w-sm">
                <button
                  type="button"
                  class="icto-team-photo-trigger"
                  aria-label="View full portrait: Dr. Mary Joyce Z. Guinto-Sali, Chancellor"
                  data-icto-team-photo-src="/images/fold-06 chancy3.png"
                  data-icto-team-photo-title="Dr. Mary Joyce Z. Guinto-Sali"
                  data-icto-team-photo-role="Chancellor"
