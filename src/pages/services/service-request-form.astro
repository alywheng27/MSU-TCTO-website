            <p id="icto-network-banner-body" class="mt-1 leading-relaxed text-slate-700 dark:text-slate-200/95"></p>
          </div>

          <div id="tour-modal-type-blurb" class="p-6 sm:p-8 space-y-8 border-b border-slate-100 dark:border-slate-700/80">
