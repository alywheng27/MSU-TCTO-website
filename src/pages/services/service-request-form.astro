  <script is:inline>
    (function () {
      const form = document.getElementById('icto-maintenance-form');
      const modal = document.getElementById('icto-form-modal');
      const panel = document.getElementById('icto-form-modal-panel');
      const modalScrollArea = document.getElementById('icto-form-modal-scroll');
      const hiddenType = document.getElementById('ict-service-type');
      const modalTitle = document.getElementById('icto-modal-title');
      const modalSubtitle = document.getElementById('icto-modal-subtitle');
      const requestDateInput = document.getElementById('req-date');
      const reqEmailInput = document.getElementById('req-email-icto');
      const reqEmailError = document.getElementById('req-email-icto-error');
      const submitButtonEl = form.querySelector('#tour-submit button[type="submit"]');
      if (!form || !modal || !hiddenType) return;

      if (requestDateInput) {
        const now = new Date();
        const localIsoDate = new Date(now.getTime() - now.getTimezoneOffset() * 60000)
          .toISOString()
          .slice(0, 10);
        requestDateInput.max = localIsoDate;
        if (!requestDateInput.value) requestDateInput.value = localIsoDate;
      }
      var ICTO_BLOCKED_EMAIL_DOMAINS = [
        'icloud.com',
        'me.com',
        'mac.com',
        'aol.com',
        'proton.me',
        'protonmail.com',
        'zoho.com',
        'gmx.com',
        'mail.com',
        'yandex.com',
        'yandex.ru',
      ];
      function setInstitutionalEmailError(msg) {
        if (!reqEmailInput) return;
        if (reqEmailError) {
          reqEmailError.textContent = msg || '';
          reqEmailError.classList.toggle('hidden', !msg);
        }
        reqEmailInput.setAttribute('aria-invalid', msg ? 'true' : 'false');
      }
      function syncInstitutionalEmailValidity() {
        if (!reqEmailInput) return true;
        var value = String(reqEmailInput.value || '').trim();
        if (!value) {
          reqEmailInput.setCustomValidity('');
          setInstitutionalEmailError('');
          return false;
        }
        var incompletePattern = /^[^\s@]+@?([^\s@]*)$/i;
        if (!/^[^\s@]+@[^\s@]+\.[^\s@]{2,}$/i.test(value)) {
          var incompleteMatch = value.match(incompletePattern);
          if (incompleteMatch) {
            reqEmailInput.setCustomValidity('Incomplete email. Please enter complete format: name@domain.com');
            setInstitutionalEmailError('Incomplete email. Please enter complete format: name@domain.com');
            return false;
          }
          reqEmailInput.setCustomValidity('Please enter a valid email address (example: name@msutcto.edu.ph).');
          setInstitutionalEmailError('Please enter a valid email address (example: name@msutcto.edu.ph).');
          return false;
        }
        var emailParts = value.match(/^[^\s@]+@([^\s@]+\.[^\s@]{2,})$/i);
        if (!emailParts) {
          reqEmailInput.setCustomValidity('Please enter a valid email address (example: name@msutcto.edu.ph).');
          setInstitutionalEmailError('Please enter a valid email address (example: name@msutcto.edu.ph).');
          return false;
        }
        var domain = String(emailParts[1] || '').toLowerCase().trim();
        if (ICTO_BLOCKED_EMAIL_DOMAINS.indexOf(domain) !== -1) {
          reqEmailInput.setCustomValidity(
            'This email domain is not accepted. Use institutional email or a common provider such as Gmail, Yahoo, Outlook, or Hotmail.'
          );
          setInstitutionalEmailError(
            'This email domain is not accepted. Use institutional email, Gmail, Yahoo, Outlook, or Hotmail.'
          );
          return false;
        }
        reqEmailInput.setCustomValidity('');
        setInstitutionalEmailError('');
        return true;
      }
      if (reqEmailInput) {
        reqEmailInput.addEventListener('input', function () {
          syncInstitutionalEmailValidity();
        });
        reqEmailInput.addEventListener('change', function () {
          syncInstitutionalEmailValidity();
        });
        reqEmailInput.addEventListener('blur', function () {
          syncInstitutionalEmailValidity();
        });
      }

      /* Dedicated iframe name so we never collide with other pages using `hidden_iframe`. */
      if (!document.querySelector('iframe[name="icto_hidden_gform_submit"]')) {
        var _ictoGgIframe = document.createElement('iframe');
        _ictoGgIframe.name = 'icto_hidden_gform_submit';
        _ictoGgIframe.title = 'Google Form submission target';
        _ictoGgIframe.setAttribute('aria-hidden', 'true');
        _ictoGgIframe.style.display = 'none';
        document.body.appendChild(_ictoGgIframe);
      }

      var humanVerifyChk = document.getElementById('icto-human-verify');
      var humanVerifyWrap = document.getElementById('icto-human-verify-wrap');
      var humanVerifyLive = document.getElementById('icto-human-verify-live');
      var captchaWrap = document.getElementById('icto-inline-captcha-wrap');
      var captchaCodeEl = document.getElementById('icto-inline-captcha-code');
      var captchaCanvas = document.getElementById('icto-inline-captcha-canvas');
      var captchaInput = document.getElementById('icto-inline-captcha-input');
      var captchaRefreshBtn = document.getElementById('icto-inline-captcha-refresh');
      var captchaMetaEl = document.getElementById('icto-inline-captcha-meta');
      var captchaErrorEl = document.getElementById('icto-inline-captcha-error');
      var generatedCaptchaCode = '';
      var captchaExpiresAtMs = 0;
      var captchaTimerId = 0;
      var captchaFailedAttempts = 0;
      var configuredTtlSeconds = Number(
        typeof window.__ICTO_CAPTCHA_TTL_SECONDS === 'string'
          ? window.__ICTO_CAPTCHA_TTL_SECONDS
          : 60
      );
      if (!Number.isFinite(configuredTtlSeconds) || configuredTtlSeconds < 15) configuredTtlSeconds = 60;
      var configuredMaxAttempts = Number(
        typeof window.__ICTO_CAPTCHA_MAX_ATTEMPTS === 'string'
          ? window.__ICTO_CAPTCHA_MAX_ATTEMPTS
          : 3
      );
      if (!Number.isFinite(configuredMaxAttempts) || configuredMaxAttempts < 1)
        configuredMaxAttempts = 3;
      configuredMaxAttempts = Math.floor(Math.min(configuredMaxAttempts, 10));
      var CAPTCHA_TTL_MS = Math.floor(configuredTtlSeconds) * 1000;
      var CAPTCHA_MAX_ATTEMPTS = configuredMaxAttempts;

      function generateInlineCaptchaCode() {
        var chars = 'ABCDEFGHJKLMNPQRSTUVWXYZ23456789';
        var out = '';
        for (var i = 0; i < 6; i++) {
          out += chars.charAt(Math.floor(Math.random() * chars.length));
        }
        return out;
      }

      function clearInlineCaptchaError() {
        if (captchaWrap) captchaWrap.classList.remove('is-invalid');
        if (captchaErrorEl) {
          captchaErrorEl.textContent = '';
          captchaErrorEl.classList.add('hidden');
        }
      }

      function stopInlineCaptchaTimer() {
        if (captchaTimerId) {
          window.clearInterval(captchaTimerId);
          captchaTimerId = 0;
        }
      }

      function updateInlineCaptchaMeta() {
        if (!captchaMetaEl) return;
        if (!captchaExpiresAtMs) {
          captchaMetaEl.textContent = '';
          return;
        }
        var leftMs = captchaExpiresAtMs - Date.now();
        var leftSec = Math.max(0, Math.ceil(leftMs / 1000));
        var attemptsLeft = Math.max(0, CAPTCHA_MAX_ATTEMPTS - captchaFailedAttempts);
        captchaMetaEl.textContent =
          'Expires in ' +
          leftSec +
          's \u00B7 Attempts left: ' +
          attemptsLeft +
          ' of ' +
          CAPTCHA_MAX_ATTEMPTS;
      }

      function beginInlineCaptchaTimer() {
        stopInlineCaptchaTimer();
        captchaExpiresAtMs = Date.now() + CAPTCHA_TTL_MS;
        updateInlineCaptchaMeta();
        captchaTimerId = window.setInterval(function () {
          var expired = Date.now() >= captchaExpiresAtMs;
          if (expired) {
            stopInlineCaptchaTimer();
            renderInlineCaptchaCode('Security code expired. A new code was generated.');
            showInlineCaptchaError('Captcha expired. Please enter the new code.');
            if (captchaInput) captchaInput.focus();
            return;
          }
          updateInlineCaptchaMeta();
        }, 1000);
      }

      function renderInlineCaptchaCode(announceText) {
        generatedCaptchaCode = generateInlineCaptchaCode();
        captchaFailedAttempts = 0;
        if (captchaCodeEl) captchaCodeEl.setAttribute('data-code', generatedCaptchaCode);
        drawInlineCaptchaImage(generatedCaptchaCode);
        if (captchaInput) {
          captchaInput.value = '';
          captchaInput.setCustomValidity('');
        }
        clearInlineCaptchaError();
        beginInlineCaptchaTimer();
        if (humanVerifyLive && announceText) humanVerifyLive.textContent = announceText;
        syncSubmitAvailability();
      }

      function drawInlineCaptchaImage(code) {
        if (!captchaCanvas || typeof captchaCanvas.getContext !== 'function') {
          if (captchaCodeEl) captchaCodeEl.textContent = code || '------';
          return;
        }
        var ctx = captchaCanvas.getContext('2d');
        if (!ctx) return;
        var w = captchaCanvas.width || 220;
        var h = captchaCanvas.height || 62;
        ctx.clearRect(0, 0, w, h);

        var grad = ctx.createLinearGradient(0, 0, w, h);
        grad.addColorStop(0, '#f8f4fb');
        grad.addColorStop(1, '#efe3f5');
        ctx.fillStyle = grad;
        ctx.fillRect(0, 0, w, h);

        for (var ni = 0; ni < 22; ni++) {
          ctx.strokeStyle = 'rgba(97,6,59,' + (0.08 + Math.random() * 0.16) + ')';
          ctx.lineWidth = 1 + Math.random() * 1.4;
          ctx.beginPath();
          ctx.moveTo(Math.random() * w, Math.random() * h);
          ctx.lineTo(Math.random() * w, Math.random() * h);
          ctx.stroke();
        }
        for (var di = 0; di < 85; di++) {
          ctx.fillStyle = 'rgba(97,6,59,' + (0.07 + Math.random() * 0.14) + ')';
          ctx.beginPath();
          ctx.arc(Math.random() * w, Math.random() * h, Math.random() * 1.5 + 0.35, 0, Math.PI * 2);
          ctx.fill();
        }

        var txt = String(code || '------');
        var seg = w / (txt.length + 1);
        for (var ti = 0; ti < txt.length; ti++) {
          var ch = txt.charAt(ti);
          var x = seg * (ti + 1);
          var y = h * (0.58 + (Math.random() * 0.12 - 0.06));
          var angle = (Math.random() * 0.38 - 0.19);
          ctx.save();
          ctx.translate(x, y);
          ctx.rotate(angle);
          ctx.font = '700 30px ui-monospace, SFMono-Regular, Menlo, Consolas, monospace';
          ctx.fillStyle = ti % 2 === 0 ? '#61063B' : '#7a1f55';
          ctx.strokeStyle = 'rgba(255,255,255,0.55)';
          ctx.lineWidth = 0.9;
          ctx.strokeText(ch, -8, 0);
          ctx.fillText(ch, -8, 0);
          ctx.restore();
        }

        ctx.globalAlpha = 0.18;
        ctx.fillStyle = '#61063B';
        for (var bi = 0; bi < 8; bi++) {
          ctx.fillRect(Math.random() * w, Math.random() * h, 1.2, 1.2);
        }
        ctx.globalAlpha = 1;
      }

      function setInlineCaptchaVisible(isVisible) {
        if (!captchaWrap || !captchaInput) return;
        captchaWrap.classList.toggle('hidden', !isVisible);
        captchaWrap.classList.toggle('is-open', !!isVisible);
        captchaInput.required = !!isVisible;
        if (isVisible) {
          renderInlineCaptchaCode('Verification enabled. Enter the generated security code.');
        } else {
          stopInlineCaptchaTimer();
          captchaExpiresAtMs = 0;
          captchaFailedAttempts = 0;
          captchaInput.value = '';
          captchaInput.required = false;
          captchaInput.setCustomValidity('');
          clearInlineCaptchaError();
          updateInlineCaptchaMeta();
        }
      }

      function isInlineCaptchaValid() {
        if (!humanVerifyChk || !humanVerifyChk.checked) return true;
        if (!captchaInput) return false;
        if (!captchaExpiresAtMs || Date.now() >= captchaExpiresAtMs) {
          renderInlineCaptchaCode('Security code expired. A new code was generated.');
          showInlineCaptchaError('Captcha expired. Please enter the new code.');
          return false;
        }
        var entered = String(captchaInput.value || '').trim();
        var expected = String(generatedCaptchaCode || '').trim();
        return !!entered && !!expected && entered === expected;
      }

      function syncSubmitAvailability() {
        if (!submitButtonEl) return;
        var allowed = false;
        if (humanVerifyChk && humanVerifyChk.checked && captchaInput) {
          var expected = String(generatedCaptchaCode || '').trim();
          var entered = String(captchaInput.value || '').trim();
          var notExpired = !!captchaExpiresAtMs && Date.now() < captchaExpiresAtMs;
          allowed = !!expected && !!entered && entered === expected && notExpired;
        }
        if (allowed) {
          submitButtonEl.removeAttribute('disabled');
          submitButtonEl.classList.remove('opacity-60', 'cursor-not-allowed');
        } else {
          submitButtonEl.setAttribute('disabled', 'disabled');
          submitButtonEl.classList.add('opacity-60', 'cursor-not-allowed');
        }
        try {
          updateIctoStepperIndicators();
        } catch (eStepSync) {
          /* ignore */
        }
      }

      function showInlineCaptchaError(msg) {
        if (captchaWrap) captchaWrap.classList.add('is-invalid');
        if (captchaErrorEl) {
          captchaErrorEl.textContent = msg;
          captchaErrorEl.classList.remove('hidden');
        }
        syncSubmitAvailability();
      }

      if (captchaRefreshBtn) {
        captchaRefreshBtn.addEventListener('click', function () {
          renderInlineCaptchaCode('A new security code was generated.');
          if (captchaInput) captchaInput.focus();
          syncSubmitAvailability();
        });
      }
      if (captchaInput) {
        captchaInput.addEventListener('input', function () {
          clearInlineCaptchaError();
          captchaInput.setCustomValidity('');
          if (humanVerifyChk && humanVerifyChk.checked) {
            var expected = String(generatedCaptchaCode || '').trim();
            var entered = String(captchaInput.value || '').trim();
            if (expected && entered.length >= expected.length && entered !== expected) {
              showInlineCaptchaError('Wrong captcha code. Please check and try again.');
            } else if (expected && entered === expected) {
              if (humanVerifyLive) {
                humanVerifyLive.textContent = 'Captcha verified. You may submit your request.';
              }
              clearInlineCaptchaError();
            }
          }
          updateInlineCaptchaMeta();
          syncSubmitAvailability();
        });
      }

      if (humanVerifyChk && humanVerifyWrap) {
        function syncHumanVerifyUi() {
          humanVerifyWrap.classList.toggle('is-verified', !!humanVerifyChk.checked);
          setInlineCaptchaVisible(!!humanVerifyChk.checked);
          if (humanVerifyLive) {
            humanVerifyLive.textContent = humanVerifyChk.checked
              ? 'Verification enabled. Complete the security code to proceed.'
              : '';
          }
          syncSubmitAvailability();
        }
        humanVerifyChk.addEventListener('change', syncHumanVerifyUi);
        syncHumanVerifyUi();
        var submitBtnHint = form.querySelector('#tour-submit button[type="submit"]');
        if (submitBtnHint) {
          submitBtnHint.addEventListener(
            'focus',
            function () {
              if (!humanVerifyChk.checked) {
                humanVerifyWrap.classList.remove('icto-human-verify--pulse');
                void humanVerifyWrap.offsetWidth;
                humanVerifyWrap.classList.add('icto-human-verify--pulse');
              }
            },
            true
          );
        }
      }

      const typeMeta = {
        emergency: {
          title: 'Emergency service request',
          subtitle: 'Urgent or critical support — triaged for priority response',
        },
        major: {
          title: 'Major service request',
          subtitle: 'Planned work, upgrades, or projects requiring coordination',
        },
        routine: {
          title: 'Routine maintenance checklist',
          subtitle: 'Standard maintenance, checklists, and non-urgent support',
        },
      };

      const blurbs = {
        emergency: 'ict-type-blurb-emergency',
        major: 'ict-type-blurb-major',
        routine: 'ict-type-blurb-routine',
      };

      function showBlurb(t) {
        document.querySelectorAll('.ict-type-blurb').forEach(function (el) {
          el.classList.add('hidden');
        });
        var id = blurbs[t];
        if (id) {
          var b = document.getElementById(id);
          if (b) b.classList.remove('hidden');
        }
      }

      function openFormModal(type) {
        if (!typeMeta[type]) return;
        hiddenType.value = type;
        form.setAttribute('data-selected-service', type);
        var checkedRole = form.querySelector('input[name="requester_role"]:checked');
        if (!checkedRole) {
          var defaultRole = form.querySelector('input[name="requester_role"][value="student"]');
          if (defaultRole) {
            defaultRole.checked = true;
            form.setAttribute('data-selected-requester', 'student');
            defaultRole.dispatchEvent(new Event('change', { bubbles: true }));
          }
        }
        modalTitle.textContent = typeMeta[type].title;
        modalSubtitle.textContent = typeMeta[type].subtitle;
        showBlurb(type);
        modal.setAttribute('aria-hidden', 'false');
        modal.classList.remove('hidden');
        void modal.offsetWidth;
        modal.classList.add('is-open');
        document.body.classList.add('overflow-hidden');
        ictoPrimeNetworkMonitoring();
        setTimeout(function () {
          var c = document.getElementById('icto-modal-close');
          if (c) c.focus();
          updateRequesterFieldLabels();
          if (typeof window.__ictSigResizeAndRefresh === 'function') {
            window.__ictSigResizeAndRefresh();
          }
          if (typeof window.__ictoUpdateStepIndicators === 'function') {
            window.__ictoUpdateStepIndicators();
          }
        }, 100);
        window.setTimeout(function () {
          if (typeof navigator !== 'undefined' && navigator.onLine === false) {
            ictoNetReachable = false;
            openIctoNetworkModal('offline', ICTO_NO_INTERNET_MODAL_MSG);
          }
        }, 320);
      }

      function closeFormModal() {
        ictoStopNetworkMonitoring();
        modal.classList.remove('is-open');
        document.body.classList.remove('overflow-hidden');
        setTimeout(function () {
          if (!modal.classList.contains('is-open')) {
            modal.classList.add('hidden');
            modal.setAttribute('aria-hidden', 'true');
          }
        }, 300);
      }

      document.querySelectorAll('.icto-svc-pick').forEach(function (btn) {
        btn.addEventListener('click', function () {
          var t = btn.getAttribute('data-service');
          openFormModal(t);
        });
      });

      document.querySelectorAll('[data-close-icto-modal]').forEach(function (el) {
        el.addEventListener('click', function (e) {
          e.preventDefault();
          closeFormModal();
        });
      });

      document.addEventListener('keydown', function (e) {
        if (e.key === 'Escape' && modal.classList.contains('is-open')) {
          closeFormModal();
        }
      });

      function val(name) {
        const el = form.elements.namedItem(name);
        if (el && 'value' in el) return (el.value || '').trim();
        return '';
      }

      /** Populated from `window.__ICTO_GOOGLE_FORM_ENTRIES` (inlined on the line above, before this script runs). */
      var ICTO_GFORM =
        typeof window !== 'undefined' &&
        window.__ICTO_GOOGLE_FORM_ENTRIES &&
        typeof window.__ICTO_GOOGLE_FORM_ENTRIES === 'object'
          ? window.__ICTO_GOOGLE_FORM_ENTRIES
          : {};

      /** Resolve value by logical Google field key (matches `ictoGoogleFormEntries` in frontmatter). */
      function gField(logicalKey) {
        if (!logicalKey || !ICTO_GFORM[logicalKey]) return '';
        var nm = ICTO_GFORM[logicalKey];
        var elDirect = form.querySelector(
          'textarea[name="' + nm + '"], input[name="' + nm + '"]:not([type="file"]), select[name="' + nm + '"]'
        );
        if (elDirect && 'value' in elDirect) return (elDirect.value || '').trim();
        return val(nm);
      }

      function valRole() {
        var c = form.querySelector('input[name="requester_role"]:checked');
        return c ? c.value : (form.getAttribute('data-selected-requester') || '').trim();
      }

      function updateRequesterFieldLabels() {
        var officeLbl = document.getElementById('ict-label-office');
        var locLbl = document.getElementById('ict-label-location');
        var officeIn = document.getElementById('req-office');
        var locIn = document.getElementById('req-location');
        if (!officeLbl || !locLbl || !officeIn || !locIn) return;
        var role = valRole();
        if (role === 'student') {
          officeLbl.textContent = 'College of';
          locLbl.textContent = 'Location';
          officeIn.setAttribute('placeholder', officeIn.getAttribute('data-placeholder-student') || '');
          locIn.setAttribute('placeholder', locIn.getAttribute('data-placeholder-student') || '');
        } else {
          officeLbl.textContent = 'Office';
          locLbl.textContent = 'Work location';
          officeIn.setAttribute('placeholder', officeIn.getAttribute('data-placeholder-staff') || 'College / unit / office');
          locIn.setAttribute('placeholder', locIn.getAttribute('data-placeholder-staff') || 'Building, room, or site');
        }
      }

      form.querySelectorAll('input[name="requester_role"]').forEach(function (r) {
        r.addEventListener('change', function () {
          form.setAttribute('data-selected-requester', r.value || '');
          updateRequesterFieldLabels();
        });
      });
      updateRequesterFieldLabels();

      const docsHelpText = document.getElementById('ict-docs-help-text');
      const docsStudent = document.getElementById('ict-docs-student');
      const docsStaffFaculty = document.getElementById('ict-docs-staff-faculty');
      const studentIdFront = document.getElementById('student-id-front');
      const studentIdBack = document.getElementById('student-id-back');
      const studentCorFile = document.getElementById('student-cor-file');
      const staffFacultyIdFront = document.getElementById('staff-faculty-id-front');
      const staffFacultyIdBack = document.getElementById('staff-faculty-id-back');

      /**
       * Re-encode raster document photos as JPEG (capped long edge, quality ladder) so uploads stay small
       * without aggressive downscaling. Target ~500 KB before a second, slightly smaller pass. Skips PDF, SVG,
       * GIF, very small files, and cases where output would not shrink.
       */
      (function initIctoDocumentImageCompression() {
        var MAX_LONG_EDGE = 2000;
        var SECOND_PASS_LONG_EDGE = 1400;
        var SOFT_MAX_BYTES = 520000;
        var SKIP_IF_SMALLER_THAN = 280000;
        var JPEG_QUALITIES = [0.88, 0.8, 0.74, 0.68, 0.62, 0.56, 0.52];

        function ictoJpegName(originalName) {
          var raw = String(originalName || 'document');
          var base = raw.replace(/\.[^.\\/]+$/i, '') || 'document';
          base = base.replace(/[^\w.\-]+/g, '_').replace(/^\.+/, '') || 'document';
          return base + '.jpg';
        }

